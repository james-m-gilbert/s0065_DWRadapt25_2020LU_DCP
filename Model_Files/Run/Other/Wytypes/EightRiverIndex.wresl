define EightRiver_Index_for_OctSep{
	value C_BB_OctSep + I_OROVL_OctSep + I_FOLSM_OctSep + Yuba_OctSep + I_ST_OctSep + I_SJ_OctSep + I_ME_OctSep + I_TU_OctSep
}
define EightRiver_Index_for_OctSep_dv{alias EightRiver_Index_for_OctSep kind 'index' units 'taf'}
define EightRiver_Index_for_OctSep_prv_yr_dv{std kind 'index' units 'taf'}

define EightRiver_Index_for_OctSep_prv_yr {
	case firstwateryear{
		condition wateryear==bgnwy 
		value 20000.
		}
	case Oct{
	condition month == Oct
	value EightRiver_Index_for_OctSep_dv (prevmay)
	}
	case otherwise {
	condition always
	value EightRiver_Index_for_OctSep_prv_yr_dv(-1)
	}
}
goal set_EightRiver_Index_for_OctSep_prv_yr_dv{
	EightRiver_Index_for_OctSep_prv_yr_dv = EightRiver_Index_for_OctSep_prv_yr
}