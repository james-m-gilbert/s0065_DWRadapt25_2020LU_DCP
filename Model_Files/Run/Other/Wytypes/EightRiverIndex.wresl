	}
	case JanMay{
		condition month>=Jan .and. month<=May
		value (sum(i=Oct-month, -1, 1) UNIMP_OROV(i))+(sum(i=0, Sep-month, 1) I_Orovl_fm_med[SWPForecast](i))
	}
	case MayDec{
		condition always
		value I_OROVL_OctSep_dv(-1)
	}
}
