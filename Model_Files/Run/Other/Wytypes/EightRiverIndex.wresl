define EightRiver_Index{
	value UNIMP_OROV + UNIMP_FOLS + UNIMP_YUBA + UNIMP_SRBB + UNIMP_ST + UNIMP_TU + UNIMP_ME + UNIMP_SJ
}
define EightRiver_Index_dv{alias EightRiver_Index kind 'index' units 'taf'}

!Forecasts to calculate sum of forecasted Eight River Index Oct-Sept
define C_BB_OctSep{
	case OctDec_1922 {
		condition month>=Oct .and. month <=Dec .and. wateryear == BgnWY
		value 3000.  !Will create avg value for Eight River Index for first 3 months, just so TUCP's won't be triggered in these months.
	}
	case JanMay{
		condition month>=Jan .and. month<=May
		value (sum(i=Oct-month, -1, 1) UNIMP_SRBB(i))+(sum(i=0, Sep-month, 1) BB_fm_med[Forecast2](i))
	}
	case MayDec{
		condition always
		value C_BB_OctSep_dv(-1)
	}
}
define C_BB_OctSep_dv {alias C_BB_OctSep kind 'index' units 'taf'}

define I_OROVL_OctSep{
