!SJRIndex_90Exe.wresl

define I_ST_OctMar90{
	case JanMar{
		condition month>=Jan .and. month<=Mar
		value (sum(i=Oct-month, -1, 1) UNIMP_ST(i))+(sum(i=0, Mar-month, 1) I_ST_fm_90[Forecast2](i))
	}
	case AprMay{
		condition month>=Apr .and. month<=May
		sum(i=Oct-month, mar-month, 1) UNIMP_ST(i)
	}
	case JunDec{
		condition always
		value 0.0
	}
}
define I_ST_OctMar90_dv{alias I_ST_OctMar90 kind 'index' units 'taf'}

define I_ST_AprJul90{
	case JanMar{
		condition month>=Jan .and. month<=Apr
		sum(i=Apr-month, Jul-month, 1) I_ST_fm_90[Forecast2](i)
	}
	case MonthMay{
		condition month==May
		value UNIMP_ST(-1) + (sum(i=0, Jul-month, 1) I_ST_fm_90[Forecast2](i))
	}
	case other{
		condition always
		value 0.0
	}
} 
define I_ST_AprJul90_dv{alias I_ST_AprJul90 kind 'index' units 'taf'}


