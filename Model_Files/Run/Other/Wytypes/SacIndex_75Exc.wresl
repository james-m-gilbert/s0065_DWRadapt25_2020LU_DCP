define yuba_AprSep_75Exc_dv{alias yuba_AprSep_75Exc kind 'index' units 'taf'}

define SacIndex_75Exc{ 
    case OCTtoDec {
         condition  month >= OCT .and. month <= Dec !water year type index for Fish and Wildlife standards in ANN (wyt_ann) renew in Jan
         value SacIndex_75Exc_dv(prevMay)
         }
    case JuntoSep {
         condition  month >= Jun .and. month <= Sep 
         value SacIndex_75Exc_dv(prevMay)
         }
    case rest {
         condition  always
	 value 0.4*(C_BB_AprJul_75Exc+i_Orovl_AprJul_75Exc+i_Folsm_AprJul_75Exc+yuba_AprJul_75Exc)+0.3*(C_BB_OctMar_75Exc+i_Orovl_OctMar_75Exc+i_Folsm_OctMar_75Exc+yuba_OctMar_75Exc)+0.3*min(10000, SacIndexPrev)
	}
}
define SacIndex_75Exc_dv{alias SacIndex_75Exc kind 'index' units 'taf'}

define WYT_Sac_Frcst_75Exc{
	case Wet{
		condition SacIndex_75Exc>9200
		value 1
	}	
	case AN{
		condition SacIndex_75Exc>7800
		value 2
	}	
	case BN{
		condition SacIndex_75Exc>6500
		value 3
	}
	case Dry{
		condition SacIndex_75Exc>5400
		value 4
	}
	case Critical{
		condition always
		value 5
	}
}
define WYT_Sac_Frcst_75Exc_dv{alias WYT_Sac_Frcst_75Exc kind 'wateryeartype' units 'none'}

define SacRiverIndex_75EXC{ 
    case OCTtoDec {
         condition  month >= OCT .and. month <= Dec 
         value SacRiverIndex_75EXC_dv(prevMay)
         }
    case JuntoSep {
         condition  month >= Jun .and. month <= Sep 
         value SacRiverIndex_75EXC_dv(prevMay)
         }
    case rest {
         condition  always
	 value (C_BB_AprSep_75EXC+i_Orovl_AprSep_75EXC+i_Folsm_AprSep_75EXC+yuba_AprSep_75EXC)+(C_BB_OctMar_75EXC+i_Orovl_OctMar_75EXC+i_Folsm_OctMar_75EXC+yuba_OctMar_75EXC)
	}
}
define SacRiverIndex_75EXC_dv{alias SacRiverIndex_75EXC kind 'index' units 'taf'}
