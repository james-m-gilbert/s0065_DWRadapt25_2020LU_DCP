! SacIndex.wresl
! SACRAMENTO VALLEY WATER YEAR TYPE INDEX  40-30-30
! Sac River Index January forcaste is used to lookup MRR flow requirement for American River
! Special computation of Sac Index and WY trype at 75% exceedance, for use with Delta VA
! Forecast calculations occur in the UPPERAMERICAN cycle in Inflows_Forecasted_CAMDLL_3.wresl, using 75% exceedance
! That cycle worked best to generate the forecasts to avoid conflicts for forecast variables and includes in other cycles

define C_BB_OctMar_75Exc{
	case JanMar{
		condition month>=Jan .and. month<=mar
		value (sum(i=Oct-month, -1, 1) UNIMP_SRBB(i))+(sum(i=0, Mar-month, 1) BB_fm[UPPERAMERICAN](i))
	}
	case AprMay{
		condition month>=Apr .and. month<=may
		value (sum(i=Oct-month, mar-month, 1) UNIMP_SRBB(i))
	}
	case JunDec{
		condition always
		value 0.0
	}
}
define C_BB_OctMar_75Exc_dv{alias C_BB_OctMar_75Exc kind 'index' units 'taf'}

define C_BB_AprJul_75Exc{
	case JanApr{
		condition month>=Jan .and. month<=Apr
		sum(i=Apr-month, Jul-month, 1) BB_fm[UPPERAMERICAN](i)
	}
	case MonthMay{
		condition month==May
		value UNIMP_SRBB(-1) + (sum(i=0, Jul-month, 1) BB_fm[UPPERAMERICAN](i))
	}
	case other{
		condition always
		value 0.0
	}
} 
define C_BB_AprJul_75Exc_dv{alias C_BB_AprJul_75Exc kind 'index' units 'taf'}

define C_BB_AprSep_75Exc{
	case JanApr{
		condition month>=Jan .and. month<=Apr
		sum(i=Apr-month, Sep-month, 1) BB_fm[UPPERAMERICAN](i)
	}
	case MonthMay{
		condition month==May
		value UNIMP_SRBB(-1) + (sum(i=0, Sep-month, 1) BB_fm[UPPERAMERICAN](i))
	}
	case other{
		condition always
		value 0.0
	}
} 
define C_BB_AprSep_75Exc_dv{alias C_BB_AprSep_75Exc kind 'index' units 'taf'}

