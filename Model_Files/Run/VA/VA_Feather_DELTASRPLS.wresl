! ************************************************************************
! Account for changes in Oroville release to support the Feather River VA action.
! I_FTR059_VAest is the amount of this month's reduced Thermalito delivery that backs up into Oroville.  
! This is ADDED to the C203_m term in the coa definition for SWPDS (Oroville storage chg)
! This term is zeroed in all but the final cycle, when it is set due to the VA action.
! C203_VA is release from Oroville necessary to create desired pulse flows for Delta Outflow.
! This is done in the final cycle of the model, concurrent with releases for wheeling and transfers
define I_FTR059_VAest {std kind 'flow-inflow' units 'cfs'}
!define I_FTR059_VAest_foregone {std kind 'flow-inflow' units 'cfs'}

!goal C_FTR059_change {I_FTR059_VAest - C_FTR059_VAest = C_FTR059_VAestBase - C_FTR059 ! ITP arcs are included here because those can change C_FTR059 flows in the last cycle
!	- Alt2BSWPExpCut_Carryover + SMSCG_Oro_Rel_for_DO + release_ITP_Carryover + remain_ITP_Carryover_Oro_rel*taf_cfs
	!+ FeatherVA_LF*taf_cfs
!}

define C_FTR059_VAest   {value FeatherVA_Relest*taf_cfs} ! Total release which includes the water block and spill release reattempts.
define C_FTR059_VAestdv {alias C_FTR059_VAest kind 'FLOW-CHANNEL' UNITS 'CFS'}
define I_FTR059_VAest_foregone  	{value FeatherVA_Foregoneest*taf_cfs} ! Total water that goes out to outflow because Oroville could not backup the water due to being at flood control
define I_FTR059_VAest_foregonedv 	{alias I_FTR059_VAest_foregone kind 'FLOW-CHANNEL' UNITS 'CFS'}

goal setOrobackup {I_FTR059_VAest = FeatherVA_Backupest*taf_cfs} ! Total water made available due to land fallowing. Can go to backup or outflow depending if Oroville is full.

define S_OROVL_VAest {lower -1000. kind 'storage' units 'taf'} 

!***************** ACCOUNTING *****************!
!ACCOUNTING ONLY - Cumulative land fallowing/ RETURN FLOW reduction volume by Mar
! Goes either to outflow or backup to Oroville
/*goal TotalFeatherVARtnFlowDiff {
