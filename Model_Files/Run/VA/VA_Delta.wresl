!General exports
define General_Delivery_Cut_Req_CVP {
    case March_C {
        condition WYT_Sac_Frcst_90Exc==5 .and. month == Mar
        value  0.}    
    case March_D {
        condition WYT_Sac_Frcst_90Exc==4 .and. month == Mar
        value 62.5}
    case March_BN {
        condition WYT_Sac_Frcst_90Exc==3 .and. month == Mar
        value 62.5}
    case March_AN { 
        condition WYT_Sac_Frcst_90Exc==2 .and. month == Mar
        value 87.5}
    case March_W { 
        condition WYT_Sac_Frcst_90Exc==1 .and. month == Mar
        value 0.} 
    case Apr_C {
        condition WYT_Sac_Frcst_75Exc==5 .and. month == Apr
        value  0.}         
    case Apr_D {
        condition WYT_Sac_Frcst_75Exc==4 .and. month == Apr
        value 62.5}
    case Apr_BN {
        condition WYT_Sac_Frcst_75Exc==3 .and. month == Apr
        value 62.5}        
    case Apr_AN { 
        condition WYT_Sac_Frcst_75Exc==2 .and. month == Apr
        value 87.5}
    case Apr_W { 
        condition WYT_Sac_Frcst_75Exc==1 .and. month == Apr
        value 0.} 
    case Mayon_C {
        condition wyt_sac==5
        value  0.}    
    case Mayon_D {
        condition wyt_sac==4 
        value 62.5}
    case Mayon_BN {
        condition wyt_sac==3 
        value 62.5}
    case Mayon_AN { 
        condition wyt_sac==2
        value 87.5}
    case Mayon_W { 
        condition wyt_sac==1
        value 0.} 	
}
define General_Delivery_Cut_Req_CVP_ {alias General_Delivery_Cut_Req_CVP kind 'FLOW-VA' units 'TAF'}
define General_Delivery_Cut_CVP_ {std kind 'VA-VOLUME' units 'taf'}


define General_Delivery_Remain_CVP {std kind 'VA-VOLUME' units 'taf'}
define General_Delivery_Remain_CVP_calc {
    case Oct1922 {
        condition month==BgnMo .and. wateryear==BgnWY
        value 0.}
    case Sep2015 {
        condition month==Sep .and. wateryear==EndWY
        value 0.}
    Case March {
    	condition month==MAR 
    	value General_Delivery_Cut_Req_CVP
    }   
    case Apr_Change {
    	condition month==APR 
    	value max (0, General_Delivery_Cut_Req_CVP-General_Delivery_Cut_CVP_(-1))
    }
    case May_Change {
    	condition month==MAY 
    	value max (0, General_Delivery_Cut_Req_CVP-General_Delivery_Cut_CVP_(-1)-General_Delivery_Cut_CVP_(-2))
    }
    case otherwise {
        condition always
        value max(0., General_Delivery_Remain_CVP(-1) - General_Delivery_Cut_CVP_(-1))}

}

define General_Delivery_Cut_CVP_annual {
		case Oct1922 {
        condition month < MAR .and. wateryear==BgnWY
        value 0.}
	case March {
		condition month==MAR
		value 0.
	}
	case otherwise{
		condition always
	sum(i=-1,prevmar,-1) General_Delivery_Cut_CVP_(i)
}
}
define General_Delivery_Cut_CVP {value max(0.,min(General_Delivery_Remain_CVP_calc,
	(EXPRed_CVPJONES_Annual-General_Delivery_Cut_CVP_annual),
	del_cvp_pag_s[WHEELJPOD]*CFS_TAF))}
goal setGeneralDelivery_Cut_CVP {General_Delivery_Cut_CVP_ = General_Delivery_Cut_CVP}
goal setGeneralDelivery_Remain_CVP {General_Delivery_Remain_CVP = General_Delivery_Remain_CVP_calc}
