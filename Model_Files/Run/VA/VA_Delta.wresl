!Difference in delivery cut compared to final requirement
define DeltaVA_CVPDelCut_Difference {     
    case Firstyr {
        condition month<=FEB .and. wateryear==BgnWY
        value 0.}
    case February {		
        condition month==FEB 
		value (General_Delivery_Cut_Req_CVP_(prevMay)+PWA_Purch_CVP_SOD_Delivery_Cut_Req_CVP_(prevMay)
		+PWA_Purch_Add_CVP_SOD_Delivery_Cut_Req_CVP_(prevMay)+PWA_Purch_WWD_SOD_Delivery_Cut_Req_CVP_(prevMay))
        -(General_Delivery_Cut_CVP_annual+General_Delivery_Cut_CVP
		+PWA_Purch_CVP_SOD_Delivery_Cut_CVP_annual+PWA_Purch_CVP_SOD_Delivery_Cut_CVP
		+PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_annual+PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP
		+PWA_Purch_WWD_SOD_Delivery_Cut_CVP_annual+PWA_Purch_WWD_SOD_Delivery_Cut_CVP) }
	case otherwise {
		condition always
		value 0.	}
}

define DeltaVA_CVPDelCut_Difference_ {alias DeltaVA_CVPDelCut_Difference kind 'FLOW-VA' units 'TAF'}
	
!Difference in delivery cut compared to final required export cut
define DeltaVA_CVPDelCut_Difference_ExpReq {     
    case Firstyr {
        condition month<=FEB .and. wateryear==BgnWY
        value 0.}
    case February {		
        condition month==FEB 
		value Export_Cut_Req_CVP_(prevMay)
        -(General_Delivery_Cut_CVP_annual+General_Delivery_Cut_CVP
		+PWA_Purch_CVP_SOD_Delivery_Cut_CVP_annual+PWA_Purch_CVP_SOD_Delivery_Cut_CVP
		+PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_annual+PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP
		+PWA_Purch_WWD_SOD_Delivery_Cut_CVP_annual+PWA_Purch_WWD_SOD_Delivery_Cut_CVP) }
	case otherwise {
		condition always
		value 0.	}
}

define DeltaVA_CVPDelCut_Difference_ExpReq_ {alias DeltaVA_CVPDelCut_Difference_ExpReq kind 'FLOW-VA' units 'TAF'}

!Difference in delivery cut compared to final actual export cut
define DeltaVA_CVPDelCut_Difference_ExpCut {     
    case Firstyr {
        condition month<=FEB .and. wateryear==BgnWY
        value 0.}
    case February {		
        condition month==FEB 
		value EXPRed_CVPJONES_Annual
        -(General_Delivery_Cut_CVP_annual+General_Delivery_Cut_CVP
		+PWA_Purch_CVP_SOD_Delivery_Cut_CVP_annual+PWA_Purch_CVP_SOD_Delivery_Cut_CVP
		+PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_annual+PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP
		+PWA_Purch_WWD_SOD_Delivery_Cut_CVP_annual+PWA_Purch_WWD_SOD_Delivery_Cut_CVP) }
	case otherwise {
		condition always
		value 0.	}
}

define DeltaVA_CVPDelCut_Difference_ExpCut_ {alias DeltaVA_CVPDelCut_Difference_ExpCut kind 'FLOW-VA' units 'TAF'}
	