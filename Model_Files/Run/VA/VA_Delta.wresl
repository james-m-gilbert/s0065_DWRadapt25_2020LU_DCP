!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!PWA Purchase WWD SOD
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
define PWA_Purch_WWD_SOD_Delivery_Cut_Req_CVP {
	case no_delive_cut {
	condition del_cvp_pag_s[WHEELJPOD]==0
	value 0.}
   	case March_C {
        condition WYT_Sac_Frcst_90Exc==5 .and. month == Mar
        value min(3., 31.185*perdel_cvpag_s)}    
    case March_D {
        condition WYT_Sac_Frcst_90Exc==4 .and. month == Mar
        value min(6., 31.185*perdel_cvpag_s)}
    case March_BN {
        condition WYT_Sac_Frcst_90Exc==3 .and. month == Mar
        value min(15., 31.185*perdel_cvpag_s)}
    case March_AN { 
        condition WYT_Sac_Frcst_90Exc==2 .and. month == Mar
        value min(19.5, 31.185*perdel_cvpag_s)}
    case March_W { 
        condition WYT_Sac_Frcst_90Exc==1 .and. month == Mar
        value min(27., 31.185*perdel_cvpag_s)}
   	case Apr_C {
        condition WYT_Sac_Frcst_75Exc==5 .and. month == Apr
        value min(3., 31.185*perdel_cvpag_s)} 
    case Apr_D {
        condition WYT_Sac_Frcst_75Exc==4 .and. month == Apr
        value min(6., 31.185*perdel_cvpag_s)}
    case Apr_BN {
        condition WYT_Sac_Frcst_75Exc==3 .and. month == Apr
        value min(15., 31.185*perdel_cvpag_s)}
    case Apr_AN { 
        condition WYT_Sac_Frcst_75Exc==2 .and. month == Apr
        value min(19.5, 31.185*perdel_cvpag_s)}
    case Apr_W { 
        condition WYT_Sac_Frcst_75Exc==1 .and. month == Apr
        value min(27., 31.185*perdel_cvpag_s)}
   	case Mayon_C {
        condition WYT_Sac==5
        value min(3., 31.185*perdel_cvpag_s)}    
    case Mayon_D {
        condition WYT_Sac==4 
        value min(6., 31.185*perdel_cvpag_s)}
    case Mayon_BN {
        condition WYT_Sac==3 
        value min(15., 31.185*perdel_cvpag_s)}
    case Mayon_AN { 
        condition WYT_Sac==2
        value min(19.5, 31.185*perdel_cvpag_s)}
    case Mayon_W { 
        condition WYT_Sac==1
        value min(27., 31.185*perdel_cvpag_s)} 	
}

define PWA_Purch_WWD_SOD_Delivery_Cut_Req_CVP_ {alias PWA_Purch_WWD_SOD_Delivery_Cut_Req_CVP kind 'FLOW-VA' units 'TAF'}
define PWA_Purch_WWD_SOD_Delivery_Cut_CVP_ {std kind 'VA-VOLUME' units 'taf'}


define PWA_Purch_WWD_SOD_Delivery_Remain_CVP {std kind 'VA-VOLUME' units 'taf'}
define PWA_Purch_WWD_SOD_Delivery_Remain_CVP_calc {
    case Oct1922 {
        condition month==BgnMo .and. wateryear==BgnWY
        value 0.}
    case Sep2015 {
        condition month==Sep .and. wateryear==EndWY
        value 0.}
    Case March {
    	condition month==MAR 
    	value PWA_Purch_WWD_SOD_Delivery_Cut_Req_CVP
    }   
    case Apr_Change {
    	condition month==APR 
    	value max (0, PWA_Purch_WWD_SOD_Delivery_Cut_Req_CVP-PWA_Purch_WWD_SOD_Delivery_Cut_CVP_(-1))
    }
    case May_Change {
    	condition month==MAY 
    	value max (0, PWA_Purch_WWD_SOD_Delivery_Cut_Req_CVP-PWA_Purch_WWD_SOD_Delivery_Cut_CVP_(-1)-PWA_Purch_WWD_SOD_Delivery_Cut_CVP_(-2))
    }
 
     case otherwise {
        condition always
        value max(0., PWA_Purch_WWD_SOD_Delivery_Remain_CVP(-1) - PWA_Purch_WWD_SOD_Delivery_Cut_CVP_(-1))}

}

define PWA_Purch_WWD_SOD_Delivery_Cut_CVP_annual {
		case Oct1922 {
        condition month < MAR .and. wateryear==BgnWY
        value 0.}
	case March {
		condition month==MAR
		value 0.
	}
	case otherwise{
		condition always
	sum(i=-1,prevmar,-1) PWA_Purch_WWD_SOD_Delivery_Cut_CVP_(i)
}
}

define WWD_cvp_pag_total_whljpod {value D_CAA095_90_PA1[WHEELJPOD] + D_CAA109_90_PA1[WHEELJPOD] + D_CAA122_90_PA1[WHEELJPOD] + D_CAA133_90_PA1[WHEELJPOD] + D_CAA143_90_PA1[WHEELJPOD] + D_CAA155_90_PA1[WHEELJPOD] + D_CAA165_90_PA1[WHEELJPOD]  + D_CAA172_90_PA1[WHEELJPOD]}
define WWD_General_Cut_total {value General_cut_D_CAA095_90_PA1 + General_cut_D_CAA109_90_PA1 + General_cut_D_CAA122_90_PA1 + General_cut_D_CAA133_90_PA1  + General_cut_D_CAA143_90_PA1 + General_cut_D_CAA155_90_PA1 + General_cut_D_CAA165_90_PA1  + General_cut_D_CAA172_90_PA1}
define WWD_PWA_Purch_Cut_total {value PWA_Purch_CVP_SOD_cut_D_CAA095_90_PA1 + PWA_Purch_CVP_SOD_cut_D_CAA109_90_PA1 + PWA_Purch_CVP_SOD_cut_D_CAA122_90_PA1 + PWA_Purch_CVP_SOD_cut_D_CAA133_90_PA1 + PWA_Purch_CVP_SOD_cut_D_CAA143_90_PA1 + PWA_Purch_CVP_SOD_cut_D_CAA155_90_PA1 + PWA_Purch_CVP_SOD_cut_D_CAA165_90_PA1 + PWA_Purch_CVP_SOD_cut_D_CAA172_90_PA1 }

define WWD_cvp_pag_total_whljpoddv {alias WWD_cvp_pag_total_whljpod kind 'QA-QC' units 'TAF'}
define WWD_General_Cut_totaldv {alias WWD_General_Cut_total kind 'QA-QC' units 'TAF'}
define WWD_PWA_Purch_Cut_totaldv {alias WWD_PWA_Purch_Cut_total kind 'QA-QC' units 'TAF'}

define PWA_Purch_WWD_SOD_Delivery_Cut_CVP {value max(0.,min(PWA_Purch_WWD_SOD_Delivery_Remain_CVP_calc,
	(EXPRed_CVPJONES_Annual-General_Delivery_Cut_CVP_annual-General_Delivery_Cut_CVP
		-PWA_Purch_CVP_SOD_Delivery_Cut_CVP_annual-PWA_Purch_CVP_SOD_Delivery_Cut_CVP
		-PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_annual-PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP
		-PWA_Purch_WWD_SOD_Delivery_Cut_CVP_annual),
	(WWD_cvp_pag_total_whljpod*CFS_TAF -WWD_General_Cut_total-WWD_PWA_Purch_Cut_total)))}
goal setPWA_Purch_WWD_SODDelivery_Cut_CVP {PWA_Purch_WWD_SOD_Delivery_Cut_CVP_ = PWA_Purch_WWD_SOD_Delivery_Cut_CVP}
goal setPWA_Purch_WWD_SODDelivery_Remain_CVP {PWA_Purch_WWD_SOD_Delivery_Remain_CVP = PWA_Purch_WWD_SOD_Delivery_Remain_CVP_calc}


