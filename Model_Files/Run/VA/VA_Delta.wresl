!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!PWA Purchase Add CVP SOD
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
define PWA_Purch_Add_CVP_SOD_Delivery_Cut_Req_CVP {
    case March_C {
        condition WYT_Sac_Frcst_90Exc==5 .and. month == Mar
        value  0.}    
    case March_D {
        condition WYT_Sac_Frcst_90Exc==4 .and. month == Mar
        value min(5., CL_71_PA5*perdel_cvpag_s)}
    case March_BN {
        condition WYT_Sac_Frcst_90Exc==3 .and. month == Mar
        value min(5., CL_71_PA5*perdel_cvpag_s)}
    case March_AN { 
        condition WYT_Sac_Frcst_90Exc==2 .and. month == Mar
        value min(5., CL_71_PA5*perdel_cvpag_s)}
    case March_W { 
        condition WYT_Sac_Frcst_90Exc==1 .and. month == Mar
        value 0.} 
    case Apr_C {
        condition WYT_Sac_Frcst_75Exc==5 .and. month == Apr
        value  0.}        
    case Apr_D {
        condition WYT_Sac_Frcst_75Exc==4 .and. month == Apr
        value min(5., CL_71_PA5*perdel_cvpag_s)}        
    case Apr_BN {
        condition WYT_Sac_Frcst_75Exc==3 .and. month == Apr
        value min(5., CL_71_PA5*perdel_cvpag_s)}
    case Apr_AN { 
        condition WYT_Sac_Frcst_75Exc==2 .and. month == Apr
        value min(5., CL_71_PA5*perdel_cvpag_s)}
    case Apr_W { 
        condition WYT_Sac_Frcst_75Exc==1 .and. month == Apr
        value 0.} 
  	case Mayon_C {
        condition WYT_Sac==5
        value  0.}    
    case Mayon_D {
        condition WYT_Sac==4 
        value min(5., CL_71_PA5*perdel_cvpag_s)}
    case Mayon_BN {
        condition WYT_Sac==3 
        value min(5., CL_71_PA5*perdel_cvpag_s)}
    case Mayon_AN { 
        condition WYT_Sac==2
        value min(5., CL_71_PA5*perdel_cvpag_s)}
    case Mayon_W { 
        condition WYT_Sac==1
        value 0.} 	
}

define PWA_Purch_Add_CVP_SOD_Delivery_Cut_Req_CVP_ {alias PWA_Purch_Add_CVP_SOD_Delivery_Cut_Req_CVP kind 'FLOW-VA' units 'TAF'}
define PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_ {std kind 'VA-VOLUME' units 'taf'}


define PWA_Purch_Add_CVP_SOD_Delivery_Remain_CVP {std kind 'VA-VOLUME' units 'taf'}
define PWA_Purch_Add_CVP_SOD_Delivery_Remain_CVP_calc {
    case Oct1922 {
        condition month==BgnMo .and. wateryear==BgnWY
        value 0.}
    case Sep2015 {
        condition month==Sep .and. wateryear==EndWY
        value 0.}
    Case March {
    	condition month==MAR 
    	value PWA_Purch_Add_CVP_SOD_Delivery_Cut_Req_CVP
    }   
    case Apr_Change {
    	condition month==APR 
    	value max (0, PWA_Purch_Add_CVP_SOD_Delivery_Cut_Req_CVP-PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_(-1))
    }
    case May_Change {
    	condition month==MAY 
    	value max (0, PWA_Purch_Add_CVP_SOD_Delivery_Cut_Req_CVP-PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_(-1)-PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_(-2))
    }
 
     case otherwise {
        condition always
        value max(0., PWA_Purch_Add_CVP_SOD_Delivery_Remain_CVP(-1) - PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_(-1))}

}

define PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_annual {
		case Oct1922 {
        condition month < MAR .and. wateryear==BgnWY
        value 0.}
	case March {
		condition month==MAR
		value 0.
	}
	case otherwise{
		condition always
	sum(i=-1,prevmar,-1) PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_(i)
}
}


define PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP {value max(0.,min(PWA_Purch_Add_CVP_SOD_Delivery_Remain_CVP_calc,
	(EXPRed_CVPJONES_Annual-General_Delivery_Cut_CVP_annual-General_Delivery_Cut_CVP
		-PWA_Purch_CVP_SOD_Delivery_Cut_CVP_annual-PWA_Purch_CVP_SOD_Delivery_Cut_CVP
		-PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_annual),
	(D_DMC044_71_PA5[WHEELJPOD]*CFS_TAF - General_cut_71_PA5 - PWA_Purch_CVP_SOD_cut_71_PA5)))}
goal setPWA_Purch_Add_CVP_SODDelivery_Cut_CVP {PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP_ = PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP}
goal setPWA_Purch_Add_CVP_SODDelivery_Remain_CVP {PWA_Purch_Add_CVP_SOD_Delivery_Remain_CVP = PWA_Purch_Add_CVP_SOD_Delivery_Remain_CVP_calc}

!define PWA_Purch_Add_CVP_SOD_cut_71_PA5 {value PWA_Purch_Add_CVP_SOD_Delivery_Cut_CVP*D_DMC044_71_PA5[WHEELJPOD]/del_cvp_pag_s[WHEELJPOD]}
define PWA_Purch_Add_CVP_SOD_cut_71_PA5 {
	case no_delive_cut {
