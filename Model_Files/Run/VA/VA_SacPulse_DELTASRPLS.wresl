!define SacVA_CumLF_Creditest {std kind 'VA-taf' units 'TAF'}	!Cumulative land fallowing/ delivery reduction volume; accounting only
!define SacVA_CumLF_backupest {std kind 'VA-taf' units 'TAF'}	!Cumulative land fallowing/ delivery reduction volume; accounting only
!define SacVA_Cum_RtnDiffest {std kind 'VA-taf' units 'TAF'}	!Cumulative land fallowing/ delivery reduction volume; accounting only
!define SacVA_CumLF_RtnDiffest {std kind 'VA-taf' units 'TAF'}	!Cumulative land fallowing/ delivery reduction volume; accounting only

