! VA_SacPulse.wresl
! Foregone delivery to Sac River Settlement Contractors supports add'l Sac River flow.

! ************************************************************************
!Need to be defined in order to access prior cycle values in the code below
define Sac_Pulse_DV  {std kind 'VA_flow'   units 'cfs'}
define Dry_yr_carryover_DV  {std kind 'VA_flow'   units 'taf'}
define SP_SHSTA_VADV  {std kind 'VOLUME-SPILL' units 'TAF'}
define SacVAVol_ {std kind 'FLOW-VA' units 'TAF'}
define I_SHSTA_VA {std kind 'flow-inflow' units 'cfs'}

! But zero out since VA operation does not actually occur in this cycle
goal zeroSac_Pulse_DV    {Sac_Pulse_DV = 0.}
goal zeroDry_yr_carryover_DV    {Dry_yr_carryover_DV = 0.}
goal setSP_SHSTA_VAdv  {SP_SHSTA_VAdv = 0.} 
goal setSacVAVol_     {SacVAVol_ = 0.} 
goal zeroI_SHSTA_VA    {I_SHSTA_VA = 0.}
goal zeroS_SHSTA_VA    {S_SHSTA_VA = 0.}
goal zeroC_KSWCK_VA    {C_KSWCK_VA = 0.}

!Not used here, but needs to be defined since it is in the Weight file
define NetDelivRed_notbackedup {std kind 'VA-cfs' units 'cfs'}		!
goal setNetDelivRed_notbackedup {NetDelivRed_notbackedup = 0.}

define SacVAVolest {
	case BegWY1 {
		condition wateryear == 1922 .and. month == Oct
		value 0. }
	case Aprilset {
		condition month == Apr
		select sac from VA_Targ_2022 where  wyt=wyt_SAC
	}
	case fixtoApr {
		condition range(month,May,Jan)
		value SacVAVol_(-1)
	}
	case otherwise {
		condition always
		value 0.}
}
define SacVAVolest_ {alias SacVAVolest kind 'FLOW-VA' units 'TAF'}

define SacVAAnnest {										!Sac VA Action volume.
	case BegWY1 {
		condition wateryear == 1922 .and. month == Oct
		value 0. }
	case SacVAoff {
		condition simulateSacVA < 0.5
		value 0.}
	case VAOperationsSTART {
		condition month == Apr		!available in all WYTs Sac 40-30-30 W, AN, BN, D, and C (W, C yr now added for 2022 MOU purchased water)
		value SacVAVolest}											!50 TAF
	case rest {
		condition range(month,May,Jan) ! Land fallowing starts from April to January
		value SacVAAnnest_(-1)
	}
	case VAOperationsOFF {
		condition always
		value 0.}
}
define SacVAAnnest_ {alias SacVAAnnest kind 'FLOW-VA' units 'TAF'}

!define SC_DelivRedest {std kind 'VA-cfs' units 'cfs'}		!
!define SC_LF_Returnsest {std kind 'VA-cfs' units 'cfs'}		!
