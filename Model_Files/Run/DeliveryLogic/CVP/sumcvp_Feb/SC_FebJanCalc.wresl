! SumUD_FebCalc_03_SU_sv   - PeakUD_FebCalc_03_SU_sv  
! Assume Redding urban settlement contract is not restricted to April-October         
define SumUD_FebCalc_03_SU  {std kind 'URBAN-DEMAND' units 'TAF'} ! Annual demand
define PeakUD_FebCalc_03_SU {std kind 'URBAN-DEMAND' units 'TAF'} ! Peak demand

! Summation of annual urban demand (March-February)
define SumUD_FebCalc_03_SU_sv {
    case octBgnWY{
        condition month == oct .and. wateryear==bgnWY
        sum(i=0,11,1) UD_03_SU(i)*cfs_taf(i) }
    case FebEndWY {
        condition month == Feb .and. wateryear==EndWY
        sum(i=prevOCT,SEP-month,1) UD_03_SU(i)*cfs_taf(i) }
    case February {
        condition month == Feb .and. wateryear < EndWY
        sum(i=Mar-month,Feb-month+12,1) UD_03_SU(i)*cfs_taf(i) }
    case otherwise {
        condition   always
        value SumUD_FebCalc_03_SU(-1) }
}
goal setSumUD_FebCalc_03_SU      {SumUD_FebCalc_03_SU = SumUD_FebCalc_03_SU_sv}

! Summation of peak urban demand (July-August)
define PeakUD_FebCalc_03_SU_sv {
    case begin {
        condition month == oct .and. wateryear == bgnWY
        value 0.0 }
    case February {
        condition month == Feb
        sum(i=Jul-month,Aug-month,1) UD_03_SU(i)*cfs_taf(i) }
    case otherwise {
        condition   always
        value PeakUD_FebCalc_03_SU(-1) }
}
goal setPeakUD_FebCalc_03_SU     {PeakUD_FebCalc_03_SU = PeakUD_FebCalc_03_SU_sv}
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

