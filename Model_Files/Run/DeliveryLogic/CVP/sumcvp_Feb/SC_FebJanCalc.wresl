!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!!! CVP Settlement Contractors !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
! Calculated in Feb for use in projecting Shasta conditions - sum of the following Mar-Feb year

! SumAW_FebCalc_02_SA_sv   - PeakAW_FebCalc_02_SA_sv  
define SumAW_FebCalc_02_SA       {std kind 'ANNUAL-APPLIED-WATER' units 'TAF'} ! Annual demand
define PeakAW_FebCalc_02_SA      {std kind 'PEAK-APPLIED-WATER' units 'TAF'} ! Peak demand

! Summation of annual applied water (April-October)
define SumAW_FebCalc_02_SA_sv {
    case octBgnWY{
        condition month == oct .and. wateryear==bgnWY
        sum(i=6,12,1) AWR_02_SA(i)*cfs_taf(i)*(1+ RPF_02_SA - RUFr5_TS(i)) + AWO_02_SA(i)*cfs_taf(i)*(1+ RPF_02_SA - RUFo_02_SA)}
    case FebEndWY {
        condition month == Feb .and. wateryear==EndWY
        value (sum(i=Apr-month,Sep-month,1) AWR_02_SA(i)*cfs_taf(i)*(1+ RPF_02_SA - RUFr5_TS(i)) + AWO_02_SA(i)*cfs_taf(i)*(1+ RPF_02_SA - RUFo_02_SA))
        + AWR_02_SA(prevOCT)*cfs_taf(prevOCT)*(1+ RPF_02_SA - RUFr5_TS(prevOCT)) + AWO_02_SA(prevOCT)*cfs_taf(prevOCT)*(1+ RPF_02_SA - RUFo_02_SA)}
    case February {
        condition month == Feb .and. wateryear < EndWY
        sum(i=Apr-month,Oct+12-month,1) AWR_02_SA(i)*cfs_taf(i)*(1+ RPF_02_SA - RUFr5_TS(i)) + AWO_02_SA(i)*cfs_taf(i)*(1+ RPF_02_SA - RUFo_02_SA)}
    case otherwise {
        condition   always
        value SumAW_FebCalc_02_SA(-1) }
}       
goal setSumAW_FebCalc_02_SA      {SumAW_FebCalc_02_SA = SumAW_FebCalc_02_SA_sv}

! Summation of peak applied water (July-August)
define PeakAW_FebCalc_02_SA_sv {
    case begin {
        condition month == oct .and. wateryear == bgnWY
        value 0.0 }
    case February {
        condition month == Feb
        sum(i=Jul-month,Aug-month,1) AWR_02_SA(i)*cfs_taf(i)*(1+ RPF_02_SA - RUFr5_TS(i)) + AWO_02_SA(i)*cfs_taf(i)*(1+ RPF_02_SA - RUFo_02_SA)}
    case otherwise {
        condition   always
        value PeakAW_FebCalc_02_SA(-1) }
}    
goal setPeakAW_FebCalc_02_SA     {PeakAW_FebCalc_02_SA = PeakAW_FebCalc_02_SA_sv}
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

