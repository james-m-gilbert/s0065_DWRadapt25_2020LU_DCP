        sum(i=prevOCT,SEP-month,1) AWR_17N_PR(i)*cfs_taf(i)*(1+ RPF_17N_PR - RUFr5_TS(i))}
    case February { ! February for wateryears BgnWY - year before EndWY
        condition month == Feb .and. wateryear < EndWY
        sum(i=Mar-month,Feb-month+12,1)  AWR_17N_PR(i)*cfs_taf(i)*(1+ RPF_17N_PR - RUFr5_TS(i))}
    case Rest { 
        condition always
        value AWRyear_FebCalc_17N_PRdv(-1) } }
goal setAWRyear_FebCalc_17N_PRdv {AWRyear_FebCalc_17N_PRdv = AWRyear_FebCalc_17N_PR}

