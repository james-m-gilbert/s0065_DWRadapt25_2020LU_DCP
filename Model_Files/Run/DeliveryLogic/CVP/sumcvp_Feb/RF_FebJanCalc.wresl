!**********************************************************************************
!Define Annual Applied Water Wetlands Demand for CVP NOD Refuge
!**********************************************************************************

define AWWyear_FebCalc_08N_PR1dv {std kind 'ANNUAL-APPLIED-WATER' units 'taf'}       			
define AWWyear_FebCalc_08N_PR1{   
    case octBgnWY {  ! special case for first wateryear, Sum Oct-Sep
        condition month == OCT .and. wateryear == bgnWY
        sum(i=0,11,1)  AWW_08N_PR1(i)*cfs_taf(i)*(1+ RPF_08N_PR1 - RUFw_08N_PR1)}  !RUFw_08N_PR1)}  !Z.Q. Richard 04/05/2012
    case FebEndWY {  ! special case for last wateryear, Sum Oct-Sep
        condition month == Feb .and. wateryear == EndWY
        sum(i=prevOCT,SEP-month,1) AWW_08N_PR1(i)*cfs_taf(i)*(1+ RPF_08N_PR1 -  RUFw_08N_PR1)}  !RUFw_08N_PR1)} 
    case February { ! February for wateryears BgnWY - year before EndWY
        condition month == Feb .and. wateryear < EndWY
        sum(i=Mar-month,Feb-month+12,1)  AWW_08N_PR1(i)*cfs_taf(i)*(1+ RPF_08N_PR1 - RUFw_08N_PR1)} ! RUFw_08N_PR1)}  
    case Rest { 
        condition always
        value AWWyear_FebCalc_08N_PR1dv(-1) } }
goal setAWWyear_FebCalc_08N_PR1dv {AWWyear_FebCalc_08N_PR1dv = AWWyear_FebCalc_08N_PR1}
       			       			
