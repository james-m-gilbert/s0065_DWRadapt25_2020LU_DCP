! Calculated in Feb for use in projecting Shasta conditions - sum of the following Mar-Feb year

!**********************************************************************************
!Define Annual Applied Water Rice Demand for CVP NOD Refuge
!**********************************************************************************

define AWRyear_FebCalc_08N_PR1dv {std kind 'ANNUAL-APPLIED-WATER' units 'taf'}       			
define AWRyear_FebCalc_08N_PR1{   
    case octBgnWY {  ! special case for first wateryear, Sum Oct-Sep
        condition month == OCT .and. wateryear == bgnWY
        sum(i=0,11,1)  AWR_08N_PR1(i)*cfs_taf(i)*(1+ RPF_08N_PR1 - RUFr5_TS(i))}
    case FebEndWY {  ! special case for last wateryear, Sum Oct-Sep
        condition month == Feb .and. wateryear == EndWY
        sum(i=prevOCT,SEP-month,1) AWR_08N_PR1(i)*cfs_taf(i)*(1+ RPF_08N_PR1 - RUFr5_TS(i))}
    case February { ! February for wateryears BgnWY - year before EndWY
        condition month == Feb .and. wateryear < EndWY
        sum(i=Mar-month,Feb-month+12,1)  AWR_08N_PR1(i)*cfs_taf(i)*(1+ RPF_08N_PR1 - RUFr5_TS(i))}
    case Rest { 
        condition always
        value AWRyear_FebCalc_08N_PR1dv(-1) } }
goal setAWRyear_FebCalc_08N_PR1dv {AWRyear_FebCalc_08N_PR1dv = AWRyear_FebCalc_08N_PR1}
       			       			
define AWRyear_FebCalc_08N_PR2dv {std kind 'ANNUAL-APPLIED-WATER' units 'taf'}       			     			
define AWRyear_FebCalc_08N_PR2{   
    case octBgnWY {  ! special case for first wateryear, Sum Oct-Sep
        condition month == OCT .and. wateryear == bgnWY
        sum(i=0,11,1)  AWR_08N_PR2(i)*cfs_taf(i)*(1+ RPF_08N_PR2 - RUFr5_TS(i))}
    case FebEndWY {  ! special case for last wateryear, Sum Oct-Sep
        condition month == Feb .and. wateryear == EndWY
        sum(i=prevOCT,SEP-month,1) AWR_08N_PR2(i)*cfs_taf(i)*(1+ RPF_08N_PR2 - RUFr5_TS(i))}
    case February { ! February for wateryears BgnWY - year before EndWY
        condition month == Feb .and. wateryear < EndWY
        sum(i=Mar-month,Feb-month+12,1)  AWR_08N_PR2(i)*cfs_taf(i)*(1+ RPF_08N_PR2 - RUFr5_TS(i))}
    case Rest { 
        condition always
        value AWRyear_FebCalc_08N_PR2dv(-1) } }
goal setAWRyear_FebCalc_08N_PR2dv {AWRyear_FebCalc_08N_PR2dv = AWRyear_FebCalc_08N_PR2}
       			       			
