        sum(i=Mar-month,Feb-month+12,1)  AWR_08S_PR(i)*cfs_taf(i)*(1+ RPF_08S_PR - RUFr5_TS(i))}
    case Rest { 
            condition always
            value AWRyear_FebCalc_08S_PRdv(-1) } }
goal setAWRyear_FebCalc_08S_PRdv {AWRyear_FebCalc_08S_PRdv = AWRyear_FebCalc_08S_PR}
       			        			
define AWRyear_FebCalc_17N_PRdv {std kind 'ANNUAL-APPLIED-WATER' units 'taf'}        			
