! SETTLEMENT CONTRACT DEMANDS *********************************************

define Apr_AW_02_SAdv {std kind 'ANNUAL-APPLIED-WATER' units 'taf'}  
define Apr_AW_02_SA {
    case Feb { 
        condition month == Feb 
        value (AWR_02_SA(Apr-month)*(1+ RPF_02_SA - RUFr5_TS(Apr-month)) 
             + AWO_02_SA(Apr-month)*(1+ RPF_02_SA - RUFo_02_SA))
             * cfs_taf(Apr-month)}
    case MarApr {
        condition month >= Mar .and. month <= Apr 
        value Apr_AW_02_SAdv(-1) }
    case otherwise {
        condition always
        value 0 }
}
goal setApr_AW_02_SAdv {Apr_AW_02_SAdv = Apr_AW_02_SA}

