define NowApr_UD_03_SU {
    case FebApr { 
        condition month >= Feb .and. month <= Apr 
        sum(i=0,Apr-month,1) UD_03_SU(i) * cfs_taf(i)}
    case otherwise {
        condition always
        value 0 }
}
define NowApr_UD_03_SUdv {alias NowApr_UD_03_SU kind 'URBAN-DEMAND' units 'taf'}

