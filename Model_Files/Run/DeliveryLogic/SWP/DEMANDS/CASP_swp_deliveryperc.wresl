		rhs D_CAA251_15_PU / (DEM_CAA251_15_PU*taf_cfs*perdel_15)
		lhs>rhs constrain
		lhs<rhs constrain}
}

goal setequal_p30 { !Equal distribution of deliveries percetwise when all contract types have demand
	lhs perdel_p30_swp_ag
	case dem0_ag { 
		condition perdel_16 == 0.0 .or. DEM_CAA251_16_PAG == 0.0 
		rhs 0.0
		lhs>rhs constrain
		lhs<rhs constrain }
	case dem0_mi { 
		condition perdel_15 == 0.0 .or. DEM_CAA251_15_PU == 0.0
		rhs perdel_p30_swp_ag
		lhs>rhs constrain
		lhs<rhs constrain }
	case other {
		condition always
		rhs perdel_p30_swp_mi
		lhs>rhs constrain
		lhs<rhs constrain }
}