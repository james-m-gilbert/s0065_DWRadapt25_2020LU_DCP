
!! This file includes logic that makes delivery shortages equal amongst Pool deliveries with multiple 
!! contract types being diverted out of each pool. 

! Pool 22 Equal Delivery Percentage
define perdel_p22_swp_ag1 { std kind 'DELIVERY-PERC-SWP-AG' units 'none'}
define perdel_p22_swp_ag2 { std kind 'DELIVERY-PERC-SWP-AG' units 'none'}
define perdel_p22_swp_ag3 { std kind 'DELIVERY-PERC-SWP-AG' units 'none'}
define perdel_p22_swp_ag4 { std kind 'DELIVERY-PERC-SWP-AG' units 'none'}

goal perdel_p22_swp_ag_1 { 
	lhs perdel_p22_swp_ag1
	case dem0 { !If demand is 0, then perdel = 0
		condition perdel_14 == 0.0 .or. DEM_14_PA == 0.0
		rhs 0.0	
		lhs>rhs constrain
		lhs<rhs constrain }
	case other {
		condition always
		rhs D_CAA185_EMPIRE_PAG / (DEM_14_PA *taf_cfs*perdel_14) 
		lhs>rhs constrain
		lhs<rhs constrain}
}
goal perdel_p22_swp_ag_2 { 
	lhs perdel_p22_swp_ag2
	case dem0 { !If demand is 0, then perdel = 0
		condition perdel_10 == 0.0 .or. DEM_10_PA == 0.0
		rhs 0.0	
		lhs>rhs constrain
		lhs<rhs constrain }
	case other {
		condition always
		rhs D_CAA185_KINGS_PAG / (DEM_10_PA *taf_cfs*perdel_10) 
		lhs>rhs constrain
		lhs<rhs constrain}
}
goal perdel_p22_swp_ag_3 { 
	lhs perdel_p22_swp_ag3
	case dem0 { !If demand is 0, then perdel = 0
		condition perdel_37 == 0.0 .or. DEM_37_PA == 0.0
		rhs 0.0	
		lhs>rhs constrain
		lhs<rhs constrain }
	case other {
		condition always
		rhs D_CAA185_TULARE_PAG / (DEM_37_PA *taf_cfs*perdel_37) 
		lhs>rhs constrain
		lhs<rhs constrain}
}
goal perdel_p22_swp_ag_4 { 
	lhs perdel_p22_swp_ag4
	case dem0 { !If demand is 0, then perdel = 0
		condition perdel_13 == 0.0 .or. DEM_13_PA == 0.0
		rhs 0.0	
		lhs>rhs constrain
		lhs<rhs constrain }
	case other {
		condition always
		rhs D_CAA185_DUDLEY_PAG / (DEM_13_PA *taf_cfs*perdel_13) 
		lhs>rhs constrain
		lhs<rhs constrain}
}

goal setequal_pool22_evendel_1 { !Equal distribution of deliveries percentwise when all contract types have demand
	lhs perdel_p22_swp_ag1
	case demabv0 { 
		condition min( perdel_14, perdel_10, perdel_37, perdel_13, DEM_14_PA, DEM_10_PA, DEM_37_PA, DEM_13_PA ) > 0.0 
		rhs perdel_p22_swp_ag2
		lhs>rhs constrain
		lhs<rhs constrain }
	case other { 
		condition always
		rhs perdel_p22_swp_ag1
		lhs>rhs constrain
		lhs<rhs constrain }
}

goal setequal_pool22_evendel_2 { !Equal distribution of deliveries percentwise when all contract types have demand
	lhs perdel_p22_swp_ag2
	case demabv0 { 
		condition min( perdel_14, perdel_10, perdel_37, perdel_13, DEM_14_PA, DEM_10_PA, DEM_37_PA, DEM_13_PA ) > 0.0 
		rhs perdel_p22_swp_ag3
		lhs>rhs constrain
		lhs<rhs constrain }
	case other { 
		condition always
		rhs perdel_p22_swp_ag2
		lhs>rhs constrain
		lhs<rhs constrain }
}

goal setequal_pool22_evendel_3 { !Equal distribution of deliveries percentwise when all contract types have demand
	lhs perdel_p22_swp_ag3
	case demabv0 { 
		condition min( perdel_14, perdel_10, perdel_37, perdel_13, DEM_14_PA, DEM_10_PA, DEM_37_PA, DEM_13_PA ) > 0.0
		rhs perdel_p22_swp_ag4
		lhs>rhs constrain
		lhs<rhs constrain }
	case other { 
		condition always
		rhs perdel_p22_swp_ag3
		lhs>rhs constrain
		lhs<rhs constrain }
}

