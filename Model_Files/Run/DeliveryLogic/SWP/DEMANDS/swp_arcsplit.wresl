/* SECTION ====================================================================
* SPILL VOLUMES AT POOL 30 (BUENA VISTA PUMPING PLANT)
* 
* Naming scheme: 
* 	- D_{aqueduct}{location}_SPILL
* 	- trigger_{pool}_SPILL
* Flows:
* 	- D_CAA251_SPILL
* Goals: 
* 	- SWP Spill = Pool 30 spill volume * (
* 		1 if I_CAA245 is greater than 75% of pool 
* 	  	capacity
* 		0 otherwise
* 	  )
*/

!Pool 30 Spill Trigger
define trigger_P30_SPILL {
	case on {
		condition I_CAA245 > CAA_P30_cap*0.75
		value 1
	}
	case otherwise {
		condition always
		value 0
	}
}
define D_CAA251_SPILL {
	lower 0. 
	upper I_CAA245 
	kind 'FLOW-DELIVERY' units 'CFS'
}
goal total_D_CAA251_SPILL {
	D_CAA251_SPILL_SWP = D_CAA251_SPILL*trigger_P30_SPILL
}

