! A. Dev 10/19/99
/* 
* This file splits any SWP Demand arc (ie. MI, PAG, PLS or PIN) PINo separate 
* sub-arcs to ensure the proper delivery pattern. The file 'swp_deliveries' 
* actually applies the proper bounds. The weights for the sub-arcs are 
* specified in the Weights-table.xPLS file. In general, 'PLS' sub-arcs should 
* have a weight greater than the 'MI' or 'PAG' sub-arc, and 'PIN' sub-arcs have 
* small weights to ensure that water is only delivered from excess supply in 
* the Delta and not from storPAGe.  This helps to ensure that losses are always 
* met and that MI and PAG demands are met before any PINerruptible water.
*
* Note:
* Atypical naming convention of "C_CAA###_##_PA", refer to memo "CalSim 3 
* Modifications for CASP" Bill SMith Stantec Jan 25 2024. "PA" is used where 
* typically "PAG" is used.
* 
* INCLUDE:
* 	- '\CASP_swp_deliveryperc.wresl'
*/

/* SECTION ====================================================================
* DEMANDS FOR TERMINAL RESERVOIRS 
* 
* Naming scheme: 
* 	- D_{agency}_{reservoir}_{demand type}
* Demands defined:
* 	- Crestline - Lake Arrowhead WA
* 	- Metropolitan - Lake Perris
* 	- Ventura County - Pyramid Lake
* 	- Ventura County - Castaic Lake
* Goals:
* 	- Total demands = Project Demands
* 	- Project demands = PMI + PIN + PCO (These don't have Ag demands)
*/

! Crestline - Lake Arrowhead WA -----------------------------------------------
define D_SVRWD_CSTLN_PRJ    {std kind 'FLOW-DELIVERY' units 'CFS' }
define D_SVRWD_CSTLN_PMI    {std kind 'FLOW-DELIVERY' units 'CFS' }
! No Article 21 Demands
define D_SVRWD_CSTLN_PCO    {std kind 'FLOW-DELIVERY' units 'CFS' }
goal totalD_SVRWD_CSTLN     { D_SVRWD_CSTLN = D_SVRWD_CSTLN_PRJ }
goal totalD_SVRWD_CSTLN_prj { 
	D_SVRWD_CSTLN_prj = D_SVRWD_CSTLN_PMI + D_SVRWD_CSTLN_PCO
}

! Metropolitan Water District Southern CA - Lake Perris -----------------------
define D_PRRIS_MWDSC_PRJ    {std kind 'FLOW-DELIVERY' units 'CFS' }
define D_PRRIS_MWDSC_PMI    {std kind 'FLOW-DELIVERY' units 'CFS' }
define D_PRRIS_MWDSC_PIN    {std kind 'FLOW-DELIVERY' units 'CFS' }
define D_PRRIS_MWDSC_PCO    {std kind 'FLOW-DELIVERY' units 'CFS' }
goal totalD_PRRIS_MWDSC     { D_PRRIS_MWDSC = D_PRRIS_MWDSC_PRJ }
goal totalD_PRRIS_MWDSC_prj { 
	D_PRRIS_MWDSC_PRJ = 
	D_PRRIS_MWDSC_PMI + D_PRRIS_MWDSC_PIN + D_PRRIS_MWDSC_PCO
}

! Ventura County - Pyramid Lake -----------------------------------------------
define D_PYRMD_VNTRA_PRJ    {std kind 'FLOW-DELIVERY' units 'CFS' }
define D_PYRMD_VNTRA_PMI    {std kind 'FLOW-DELIVERY' units 'CFS' }
! No Article 21 Demands
define D_PYRMD_VNTRA_PCO    {std kind 'FLOW-DELIVERY' units 'CFS' }
goal totalD_PYRMD_VNTRA     { D_PYRMD_VNTRA = D_PYRMD_VNTRA_PRJ }
goal totalD_PYRMD_VNTRA_prj { 
	D_PYRMD_VNTRA_PRJ = D_PYRMD_VNTRA_PMI + D_PYRMD_VNTRA_PCO
}

! Ventura County - Castaic Lake -----------------------------------------------
define D_CSTIC_VNTRA_PRJ    {std kind 'FLOW-DELIVERY' units 'CFS' }
define D_CSTIC_VNTRA_PMI    {std kind 'FLOW-DELIVERY' units 'CFS' }
define D_CSTIC_VNTRA_PIN    {std kind 'FLOW-DELIVERY' units 'CFS' }
define D_CSTIC_VNTRA_PCO    {std kind 'FLOW-DELIVERY' units 'CFS' }
goal totalD_CSTIC_VNTRA     { D_CSTIC_VNTRA = D_CSTIC_VNTRA_PRJ }
goal totalD_CSTIC_VNTRA_prj { 
	D_CSTIC_VNTRA_PRJ = 
	D_CSTIC_VNTRA_PMI + D_CSTIC_VNTRA_PCO + D_CSTIC_VNTRA_PIN
}

