		condition perdel_cvpag_s == 0.0 
		rhs 0.0
		lhs>rhs constrain
		lhs<rhs constrain }
	case other {
		condition cyclenum < cn_ITP
		rhs perdel_p20_cvp_ag2
		lhs>rhs constrain
		lhs<rhs constrain }
}

goal setequal_pool20 { !Equal distribution of deliveries percetwise when all contract types have demand
	lhs perdel_p20_cvp_ag2
	case dem0_ag { 
		condition perdel_cvpag_s == 0.0 
		rhs 0.0
		lhs>rhs constrain
		lhs<rhs constrain }
	case dem0_mi { 
		condition perdel_cvpmi_s == 0.0 
		rhs perdel_p20_cvp_ag2
		lhs>rhs constrain
		lhs<rhs constrain }
	case other {
		condition cyclenum < cn_ITP
		rhs perdel_p20_cvp_mi
		lhs>rhs constrain
		lhs<rhs constrain }
}