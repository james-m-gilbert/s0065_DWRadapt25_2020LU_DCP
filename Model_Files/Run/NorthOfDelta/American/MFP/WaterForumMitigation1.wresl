define VAContri2_3_Total {value 30.}  ! 10 TAF for Contribution 2, 20 TAF for Contribution 3. 
define VAContri4_Total {
				 case Sep {condition month==Sep value 0.}
   				 case Oct_Feb {condition month>=Oct .and. month<=Feb value 0.}
				 case mMar {condition month == Mar  .and. wyt_SAC_VA_(1) == 4         value 5.}
				 case mApr {condition month == Apr  .and. WYT_Sac_Frcst == 4          value 5.}
				 case mMay {condition month == May  .and. WYT_Sac_Frcst_dv(-1) == 4   value 5.}
				 case otherwise {condition always value 0.}
}  ! 5 TAF for Contribution 4 in Dry years using GW substitution as per email communication with RWA (Michelle Banonis) on 4/3/2023
define VA2_3_4_Contridv {std   kind 'Res-Release' units 'TAF'}
define VA2_3_4_Contri{value (VAContri2_3_Total+VAContri4_Total)*SimulateVA_Amr*(GPmin_26N_NU1_ADD+GPmin_26N_NU2_ADD+GPmin_26N_NU3_ADD+GPmin_26N_NU4_ADD+GPmin_26N_PU1_ADD+GPmin_26N_PU2_ADD+GPmin_26N_PU3_ADD+GPmin_26S_NU1_ADD+GPmin_26S_NU2_ADD+GPmin_26S_NU3_ADD+GPmin_26S_NU4_ADD+GPmin_26S_PU1_ADD+GPmin_26S_PU2_ADD+GPmin_26S_PU3_ADD+GPmin_26S_PU4_ADD+GPmin_26S_PU5_ADD+GPmin_26S_PU6_ADD)}
goal setVA2_3_4_Contri {VA2_3_4_Contridv = VA2_3_4_Contri}
!------------------------------------------------------------------------------------------------------------------------------------------
define NDOI_ADD_AMERVA {std kind 'VA-VOLUME' units 'CFS'}
goal SetAMERVA {NDOI_ADD_AMERVA = ((VA_Contri1_HHOLEdv+VA_Contri1_CAPLSdv+VA_Contri4_HHOLEdv+VA2_3_4_Contridv)*taf_cfs)*SimulateVA_Amr_Onoff}

define releasedVAdv {std kind 'FLOW' units 'TAF'}
define releasedVA{
	case firstmonth{
		condition month==Oct
		value (VA_Contri1_HHOLE+VA_Contri4_HHOLE)
		}
	case other{
		condition always !range(month,Oct,Feb)
		value releasedVAdv(-1)+(VA_Contri1_HHOLE+VA_Contri4_HHOLE)
		}
	}

goal SetReleasedVAdv {releasedVAdv=releasedVA}


! Recovery is performed by reducing the power release by half until all VA water is recovered.
! Recovery can only occur when during a recovery year and when Folsom Reservoir is spilling
! Record all water recovered
define recoveredVAdv {std kind 'FLOW' units 'TAF'}
define recoveredVA{
	case firstmonth {
		condition month==Oct .and. wateryear==BgnWY
		value FOL_spill * MFPpow_release/2.
		}
	case VAperiod {condition range(month, Apr, Jun) value 0.}
	case recovery {
		condition /*range(month,Oct,Feb) .and.*/ deficitVAdv(-1)>0
		value recoveredVAdv(-1) + FOL_spill * MFPpow_release/2./* , deficitVAdv(prevSep))*/
		}
	case other {
		condition always
		value 0.
		}
	}

goal SetRecoveredVAdv { recoveredVAdv=recoveredVA}

define deficitVAdv {std kind 'FLOW' units 'TAF'}
define deficitVA{
	case firstmonth {
		condition month==Oct .and. wateryear==BgnWY 
		value (releasedVA-recoveredVA)*SimulateVA_Amr
		}
	case other{
		condition always
		value max((deficitVAdv(-1)/**FOL_spilldv(-1)*/ + max((releasedVA-releasedVAdv(-1)),0.)-max((recoveredVA-recoveredVAdv(-1)),0.)),0.)*SimulateVA_Amr
		}
	 }

goal SetdeficitVAdv {deficitVAdv=deficitVA}



goal setD_HHOLE_MFT003_VA  {D_HHOLE_MFT003_VA < (VA_Contri1_HHOLE+VA_Contri4_HHOLE)*SimulateVA_Amr*taf_cfs}

define S_HHOLElevel5 {case FirstYear {condition wateryear == BgnWY value S_HHOLElevel6}
	case Otherwise {condition always value S_HHOLElevel6-(deficitdv(prevSep)-deficitdv(prevSep)*FOL_spilldv(-1))}
}
! Set Hell Hole Level 4  !PK 03122020
define FRM_ReleaseTarget{case JanMay{condition range(month, Jan, May) value FRM_PowerReleaseTarget_JanMay}
						 case JunDec{condition range(month, Jun, Sep) .or. range(month, Oct, Dec) value MFPpow_FRMDW_release}
}
define debug_Outflow{value max((MIF_MFP_RUB031 + MIF_MFP_buffer)*cfs_taf,75*cfs_taf+WFmon_NFA016_ABT002,(MFPmon_FOLSM_WTPRSV+MFPSJmon_FOLSM_WTPSJP+MFPSSmon_FOLSM_WTPSJP+WFmon_NFA016_ABT002))}
define HH_Inflow{value I_Hhole*cfs_taf + LittleRubicon_min_flow1 + Rubicon_min_flow+ FRM_ReleaseTarget}!

define S_HHOLE_NoVA	{std kind 'Storage' units 'TAF'}

!define S_HHOLE_NoVA		{case AmerVA {condition SimulateVA_Amr >= 0.5 value S_HHOLE[UPPERAMERICAN]}
!						 case NoVA	 {condition  always value 0}
!}

goal setS_HHOLE_NoVA {lhs S_HHOLE_NoVA 
	 case AmerVA {condition SimulateVA_Amr >= 0.5 rhs S_HHOLE[UPPERAMERICAN] lhs < rhs penalty 99999 lhs > rhs penalty 99999}
		case noVA {condition always rhs S_HHOLE lhs < rhs penalty 99999 lhs > rhs penalty 99999}
}

define MFPpow_HHOLE_release_NoVAdv	{std kind 'RES-Release' units 'TAF'}

define MFPpow_HHOLE_release_NoVA		{case AmerVA {condition SimulateVA_Amr >= 0.5 value MFPpow_HHOLE_release[UPPERAMERICAN]}
						 case NoVA	 {condition  always value MFPpow_HHOLE_release}
}

goal setMFPpow_HHOLE_release_NoVAdv {MFPpow_HHOLE_release_NoVAdv = MFPpow_HHOLE_release_NoVA}

define AHHOLElast_NoVAdv	{std kind 'AREA' units 'ACRE'}

define AHHOLElast_NoVA		{case AmerVA {condition SimulateVA_Amr >= 0.5 value AHHOLElast[UPPERAMERICAN]}
						 case NoVA	 {condition  always value AHHOLElast}
}

goal setAHHOLElast_NoVAdv {AHHOLElast_NoVAdv = AHHOLElast_NoVA}

define S_HHOLElevel4_UpperAmerican {case UpperAmericanCycle {condition SimulateVA_Amr < 0.5 value 0}
									case UpperVA			{condition SimulateVA_Amr >= 0.5 value S_HHOLElevel4init[UPPERAMERICAN]}
}


define S_HHOLElevel4init {
		case FirstMonth {
		condition wateryear==BgnWY .and. month==Oct
		value 100. 
		}
	case JulSep    {condition range(month,Jul,Sep) 										
	                value min(S_HHOLElevel4dv(-1),max(100- WFMitRel_ann, max(S_HHOLElevel3, S_HHOLE_NoVA(-1)+HH_Inflow- MFPpow_HHOLE_release_NoVA-max((MIF_MFP_RUB031 + MIF_MFP_buffer)*cfs_taf,75*cfs_taf+WFmon_NFA016_ABT002,(MFPmon_FOLSM_WTPRSV+MFPSJmon_FOLSM_WTPSJP+MFPSSmon_FOLSM_WTPSJP+WFmon_NFA016_ABT002))
	                	-AHHOLElast_NoVA*ER_HHOLE/12000.		!max((MIF_MFP_RUB031 + MIF_MFP_buffer)*cfs_taf,75+WFmon_NFA016_ABT002*taf_cfs*cfs_taf,(D_FOLSM_WTPRSV_MFP+D_FOLSM_WTPSJP_MFP+WFmon_NFA016_ABT002*taf_cfs)*cfs_taf)
	                )))
	}
	case MonOct    {condition month == Oct										
	                value min(S_HHOLElevel4dv(-1),max(100- WFMitRel_ann, max(S_HHOLElevel3, S_HHOLE_NoVA(-1)+HH_Inflow- MFPpow_HHOLE_release_NoVA-max((MIF_MFP_RUB031 + MIF_MFP_buffer)*cfs_taf,75*cfs_taf+WFmon_NFA016_ABT002,(MFPmon_FOLSM_WTPRSV+MFPSJmon_FOLSM_WTPSJP+MFPSSmon_FOLSM_WTPSJP+WFmon_NFA016_ABT002))
	                	-AHHOLElast_NoVA*ER_HHOLE/12000.		!max((MIF_MFP_RUB031 + MIF_MFP_buffer)*cfs_taf,75+WFmon_NFA016_ABT002*taf_cfs*cfs_taf,(D_FOLSM_WTPRSV_MFP+D_FOLSM_WTPSJP_MFP+WFmon_NFA016_ABT002*taf_cfs)*cfs_taf)
	                )))
	}
	case JunorNov    {condition  month == Nov .or. month == Jun			! Period of Direct Diversion is Nov 1 - July 1							
	                value min(S_HHOLElevel4dv(-1),max(100- WFMitRel_ann, max(S_HHOLElevel3, S_HHOLE_NoVA(-1)+HH_Inflow- MFPpow_HHOLE_release_NoVA-(MIF_MFP_RUB031 + MIF_MFP_buffer)*cfs_taf-AHHOLElast_NoVA*ER_HHOLE/12000.)))
	}
	case JanApr   {condition range(month,Jan,Apr)
	               value max(S_HHOLElevel4dv(-1),max(S_HHOLElevel3,S_HHOLE_NoVA(-1)+HH_Inflow - HH_PowerReleaseTarget_JanMay-(MIF_MFP_RUB031 + MIF_MFP_buffer)*cfs_taf-AHHOLElast_NoVA*ER_HHOLE/12000.))
	}
	case MMay	  {condition month == May
					value S_HHOLElevel5
	}
	Case MonthDec {condition month == Dec
		           value 100. - WFMitRel_ann
    }
	case Otherwise {!this case will never be used
		condition always
		value 0.
	}	
}


define releaseddeduct {case mOct{condition month == Oct value 0.}
					   case otherwise {condition always value max(0.,released - releaseddv(-1))}
}

define releaseddeductdv {alias releaseddeduct kind 'Res-Release' units 'TAF'}


define deficitDeduct_VAdv {std kind 'Res-Release' units 'TAF'}
define deficitDeduct_VA	{case FirstMonth {condition month == Oct .and. wateryear == BgnWY value 0.}
						 case mJune {condition month == JUN value deficitVA}
						 case otherwise {condition always value deficitDeduct_VAdv(-1)}
}
goal setdeficitDeduct_VA {deficitDeduct_VAdv = deficitDeduct_VA}
!define S_HHOLElevel4initdv {alias S_HHOLElevel4init kind 'Storage-Level' units 'TAF'}

define S_HHOLElevel4initsv {timeseries kind 'Storage-Level' units 'TAF'}		!Without Mitigation Release

define S_HHOLElevel4in	{case Mityear {condition /*Mityr > 0.5*/ deficit >= 0.01 value S_HHOLElevel4initsv}
						 case deficitVA {condition deficitVA >= 0.01 .and. SimulateVA_Amr >= 0.5 value S_HHOLElevel4_UpperAmerican}
						 case otherwise{condition always value S_HHOLElevel4init}
}

define S_HHOLElevel4{value max(S_HHOLElevel3, min(S_HHOLElevel5,S_HHOLElevel4in - deficit - deficitVA*SimulateVA_Amr))}!releaseddeduct)}
goal SetHHOLElevel4  {S_HHOLE_4 < max (S_HHOLElevel4-S_HHOLElevel3,0.)}
define MFPpow_HHOLE_release_dv	{alias MFPpow_HHOLE_release kind 'DEBUG' UNITS 'TAF'}
define HH_PowerReleaseTarget_JanMay_dv{alias HH_PowerReleaseTarget_JanMay kind 'DEBUG' UNITS 'TAF'}

!Adjust HH max. storage limit according to the released/recovered mitigation water.
goal Set951level5 {S_HHOLE_5 < max (S_HHOLElevel5-S_HHOLElevel4,0.)}
define S_HHOLElevel5dv {alias S_HHOLElevel5}

define VA_Contri1_CAPLSdv {std kind 'Res-Release' units 'TAF'}
define VA_Contri1_CAPLS {	
	!case AboveNormal{
	!	condition month>=Apr .and. month<=Jun .and. WYT_Sac_Frcst == 3 
	!	value (10./3.)*SimulateVA_Amr!*taf_cfs
	!	}
	case Oct_Feb{
		condition month>=Oct .and. month<=Feb
		value 0.
		}
	case Sep{
		condition month==Sep
		value 0.
		}
	case AboveNormal_Mar{
		condition month==Mar .and. wyt_SAC_VA_(1)==2 
		value (3./3.)*SimulateVA_Amr!*taf_cfs
		}
	case AboveNormal_Apr{
		condition month==Apr .and. WYT_Sac_Frcst==2
		value (3./3.)*SimulateVA_Amr!*taf_cfs
		}
	case AboveNormal_May{
		condition month==May .and. WYT_Sac_Frcst_dv(-1)==2
		value (3./3.)*SimulateVA_Amr!*taf_cfs
		}
	!case BelowNormal{
	!	condition month>=Apr .and. month<=Jun .and. WYT_Sac_Frcst == 3 
	!	value (10./3.)*SimulateVA_Amr!*taf_cfs
	!	}
	case BelowNormal_Mar{
		condition month==Mar .and. wyt_SAC_VA_(1)==3 
		value (3./3.)*SimulateVA_Amr!*taf_cfs
		}
	case BelowNormal_Apr{
		condition month==Apr .and. WYT_Sac_Frcst==3
		value (3./3.)*SimulateVA_Amr!*taf_cfs
		}
	case BelowNormal_May{
		condition month==May .and. WYT_Sac_Frcst_dv(-1)==3
		value (3./3.)*SimulateVA_Amr!*taf_cfs
		}
	case otherwise{condition always value 0.}
		}
goal setVA_Contri1_CAPLSdv {VA_Contri1_CAPLSdv = VA_Contri1_CAPLS}

define releasedVA_CAPLSdv {std kind 'FLOW' units 'TAF'}
define releasedVA_CAPLS{
	case firstmonth{
		condition month==Oct
		value (VA_Contri1_CAPLS)
		}
	case other{
		condition always !range(month,Oct,Feb)
		value releasedVA_CAPLSdv(-1)+(VA_Contri1_CAPLS)
		}
	}

goal SetReleasedVA_CAPLSdv {releasedVA_CAPLSdv=releasedVA_CAPLS}
! Recovery is performed by reducing the power release by half until all VA water is recovered.
! Recovery can only occur when during a recovery year and when Folsom Reservoir is spilling
! Record all water recovered
define recoveredVA_CAPLSdv {std kind 'FLOW' units 'TAF'}
define recoveredVA_CAPLS{
	case firstmonth {
		condition month==Oct .and. wateryear==BgnWY
		value 0.
		}
	case VAperiod {condition range(month, Apr, Jun) value 0.}
	case recovery {
		condition /*range(month,Oct,Feb) .and.*/ deficitVA_CAPLSdv(-1)>0
		value recoveredVA_CAPLSdv(-1) + FOL_spill * min(deficitVA_CAPLSdv(-1), 1.)/* , deficitVAdv(prevSep))*/
		}
	case other {
		condition always
		value 0.
		}
	}

goal SetrecoveredVA_CAPLSdv { recoveredVA_CAPLSdv=recoveredVA_CAPLS}

define deficitVA_CAPLSdv {std kind 'FLOW' units 'TAF'}
define deficitVA_CAPLS{
	case firstmonth {
		condition month==Oct .and. wateryear==BgnWY 
		value (releasedVA_CAPLS-recoveredVA_CAPLS)*SimulateVA_Amr
		}
	case other{
		condition always
		value max((deficitVA_CAPLSdv(-1)/**FOL_spilldv(-1)*/ + max((releasedVA_CAPLS-releasedVA_CAPLSdv(-1)),0.)-max((recoveredVA_CAPLS-recoveredVA_CAPLSdv(-1)),0.)),0.)*SimulateVA_Amr
		}
	 }

goal SetdeficitVA_CAPLSdv {deficitVA_CAPLSdv=deficitVA_CAPLS}
