				 case mMay {condition month == May  .and. WYT_Sac_Frcst_dv(-1) >= 4   select mMay from AmericanVA_GP where ID = 11}
				 case otherwise {condition always value 0.}}
define GPmin_26S_NU4_ADDdv {alias GPmin_26S_NU4_ADD kind 'VA-GP-Multiplier' units 'NONE'}

