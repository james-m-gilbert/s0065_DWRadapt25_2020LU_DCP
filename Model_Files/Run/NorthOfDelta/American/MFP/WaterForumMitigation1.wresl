				 case Sep {condition month==Sep value 0.}
				 case mMar {condition month == Mar  .and. wyt_SAC_VA_(1) >= 4         select mMar from AmericanVA_GP where ID = 12}
				 case mApr {condition month == Apr  .and. WYT_Sac_Frcst >= 4          select mApr from AmericanVA_GP where ID = 12}
				 case mMay {condition month == May  .and. WYT_Sac_Frcst_dv(-1) >= 4   select mMay from AmericanVA_GP where ID = 12}
