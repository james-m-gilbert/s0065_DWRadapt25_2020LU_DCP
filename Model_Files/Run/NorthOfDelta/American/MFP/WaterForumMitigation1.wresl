				 case mSep {condition month==Sep value 0.}
				 case mMar {condition month == Mar  .and. wyt_SAC_VA_(1) >= 4         select mMar from AmericanVA_GP where ID = 17}
				 case mApr {condition month == Apr  .and. WYT_Sac_Frcst >= 4          select mApr from AmericanVA_GP where ID = 17}
				 case mMay {condition month == May  .and. WYT_Sac_Frcst_dv(-1) >= 4   select mMay from AmericanVA_GP where ID = 17}
				 case otherwise {condition always value 0.}}
