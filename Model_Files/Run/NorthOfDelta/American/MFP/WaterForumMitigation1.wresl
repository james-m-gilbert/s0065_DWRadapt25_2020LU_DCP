!Reservoir Reoperation in Above Normal and Below Normal Water Year Types (American Flow Contribution 1).
define  wyt_SAC_VA_         {timeseries kind 'wateryeartype' units 'none'} !Perfect foresight for BN and D in March 
define VA_Contri1_HHOLEdv {std kind 'Res-Release' units 'TAF'}
define VA_Contri1_HHOLE {	
	!case AboveNormal{
	!	condition month>=Apr .and. month<=Jun .and. WYT_Sac_Frcst == 3 
	!	value (10./3.)*SimulateVA_Amr!*taf_cfs
	!	}
	case Oct_Feb{
		condition month>=Oct .and. month<=Feb
		value 0.
		}
	case Sep{
		condition month==Sep
		value 0.
		}
	case AboveNormal_Mar{
		condition month==Mar .and. wyt_SAC_VA_(1)==2 
		value (7./3.)*SimulateVA_Amr!*taf_cfs
		}
	case AboveNormal_Apr{
		condition month==Apr .and. WYT_Sac_Frcst==2
		value (7./3.)*SimulateVA_Amr!*taf_cfs
		}
	case AboveNormal_May{
		condition month==May .and. WYT_Sac_Frcst_dv(-1)==2
		value (7./3.)*SimulateVA_Amr!*taf_cfs
		}
	!case BelowNormal{
	!	condition month>=Apr .and. month<=Jun .and. WYT_Sac_Frcst == 3 
	!	value (10./3.)*SimulateVA_Amr!*taf_cfs
	!	}
	case BelowNormal_Mar{
		condition month==Mar .and. wyt_SAC_VA_(1)==3 
		value (7./3.)*SimulateVA_Amr!*taf_cfs
		}
	case BelowNormal_Apr{
		condition month==Apr .and. WYT_Sac_Frcst==3
		value (7./3.)*SimulateVA_Amr!*taf_cfs
		}
	case BelowNormal_May{
		condition month==May .and. WYT_Sac_Frcst_dv(-1)==3
		value (7./3.)*SimulateVA_Amr!*taf_cfs
		}
	case otherwise{condition always value 0.}
		}
goal setVA_Contri1_HHOLEdv {VA_Contri1_HHOLEdv = VA_Contri1_HHOLE}

define VA_Contri1_HHOLE_Cumdv {std  kind 'Res-Release' units 'TAF'}
define VA_Contri1_HHOLE_Cum	{	
	/*case AboveNormal{
		condition month>=Apr .and. month<=Jun .and. WYT_Sac_Frcst == 2 
		value VA_Contri1_HHOLE + VA_Contri1_HHOLE_Cumdv(-1)!*taf_cfs
		}
	case BelowNormal{
		condition month>=Apr .and. month<=Jun .and. WYT_Sac_Frcst == 3 
		value VA_Contri1_HHOLE + VA_Contri1_HHOLE_Cumdv(-1)!*taf_cfs
		}*/
	case MarMay{
		!condition month>=Apr .and. month<=Jun .and. WYT_Sac_Frcst == 2 
		condition month>=Mar .and. month<=May! .and. WYT_Sac_Frcst == 2 
		value VA_Contri1_HHOLE + VA_Contri1_HHOLE_Cumdv(-1)!*taf_cfs
		}
	case otherwise{condition always value 0.}
		}

goal setVA_Contri1_HHOLE_Cumdv {VA_Contri1_HHOLE_Cumdv = VA_Contri1_HHOLE_Cum}


!	American VA Contribution 4 (Assumed to be released from Hell hole - PCWA)

!	As per email communication with RWA (Michelle Banonis) and Reclamation (Cameron Koizumi), on April 3, 2023, For contribution 4, 5 TAF should come from 
!	upstream storage (Hell Hole - 70% and Caples - 30%) and 5 TAF should come from GW subsitution

define VA_Contri4_HHOLEdv {std kind 'Res-Release' units 'TAF'}
define VA_Contri4_HHOLE {	
	!case Dry{
	!	condition month>=Apr .and. month<=Jun .and. WYT_Sac_Frcst == 4 
	!	value (10./3.)*SimulateVA_Amr!*taf_cfs
	!	}
	case Oct_Feb{
		condition month>=Oct .and. month<=Feb
		value 0.
		}
	case Sep{
		condition month==Sep
		value 0.
		}
	case Dry_Mar{
		condition month==Mar .and. wyt_SAC_VA_(1)==4
		value (5./3.)*SimulateVA_Amr!*taf_cfs
		}
	case Dry_Apr{
		condition month==Apr .and. WYT_Sac_Frcst==4
		value (5./3.)*SimulateVA_Amr!*taf_cfs
		}
	case Dry_May{
		condition month==May .and. WYT_Sac_Frcst_dv(-1)==4
		value (5./3.)*SimulateVA_Amr!*taf_cfs
		}
	case otherwise{condition always value 0.}
		}
goal setVA_Contri4_HHOLEdv {VA_Contri4_HHOLEdv = VA_Contri4_HHOLE}

define VA_Contri4_HHOLE_Cumdv {std  kind 'Res-Release' units 'TAF'}
define VA_Contri4_HHOLE_Cum	{	
	case Dry{
		!condition month>=Apr .and. month<=Jun .and. WYT_Sac_Frcst == 4 
		condition month>=Mar .and. month<=May! .and. WYT_Sac_Frcst == 4 
		value VA_Contri4_HHOLE + VA_Contri4_HHOLE_Cumdv(-1)!*taf_cfs
		}
	case otherwise{condition always value 0.}
		}

goal setVA_Contri4_HHOLE_Cumdv {VA_Contri4_HHOLE_Cumdv = VA_Contri4_HHOLE_Cum}

define VA2_3_Contridv {std   kind 'Res-Release' units 'TAF'}
!Contribution of total American VA flow
!!!Multipliers for distributing 10 TAF over different demand units based on average demands (Code Repeated in Upper American VA cycle for NDOI Estimate)
!define  wyt_SAC_VA_         {timeseries kind 'wateryeartype' units 'none'} !Perfect foresight for BN and D in March 
define GPmin_26N_NU1_ADD	{case Oct_Feb {condition month>=Oct .and. month<=Feb value 0.}
				 case Sep {condition month==Sep value 0.}
				 case mMar {condition month == Mar  .and. wyt_SAC_VA_(1) >= 4        select mMar from AmericanVA_GP where ID = 1}
				 case mApr {condition month == Apr  .and. WYT_Sac_Frcst >= 4         select mApr from AmericanVA_GP where ID = 1}
				 case mMay {condition month == May  .and. WYT_Sac_Frcst_dv(-1) >= 4  select mMay from AmericanVA_GP where ID = 1}
				 case otherwise {condition always value 0.}}
define GPmin_26N_NU1_ADDdv {alias GPmin_26N_NU1_ADD kind 'VA-GP-Multiplier' units 'NONE'}

define GPmin_26N_NU2_ADD	{case Oct_Feb {condition month>=Oct .and. month<=Feb value 0.}
				 case Sep {condition month==Sep value 0.}
				 case mMar {condition month == Mar  .and. wyt_SAC_VA_(1) >= 4        select mMar from AmericanVA_GP where ID = 2}
				 case mApr {condition month == Apr  .and. WYT_Sac_Frcst >= 4         select mApr from AmericanVA_GP where ID = 2}
				 case mMay {condition month == May  .and. WYT_Sac_Frcst_dv(-1) >= 4  select mMay from AmericanVA_GP where ID = 2}
				 case otherwise {condition always value 0.}}
define GPmin_26N_NU2_ADDdv {alias GPmin_26N_NU2_ADD kind 'VA-GP-Multiplier' units 'NONE'}

define GPmin_26N_NU3_ADD	{case Oct_Feb {condition month>=Oct .and. month<=Feb value 0.}
				 case Sep {condition month==Sep value 0.}
				 case mMar {condition month == Mar  .and. wyt_SAC_VA_(1) >= 4        select mMar from AmericanVA_GP where ID = 3}
				 case mApr {condition month == Apr  .and. WYT_Sac_Frcst >= 4         select mApr from AmericanVA_GP where ID = 3}
				 case mMay {condition month == May  .and. WYT_Sac_Frcst_dv(-1) >= 4  select mMay from AmericanVA_GP where ID = 3}
				 case otherwise {condition always value 0.}}
define GPmin_26N_NU3_ADDdv {alias GPmin_26N_NU3_ADD kind 'VA-GP-Multiplier' units 'NONE'}
				 
define GPmin_26N_NU4_ADD	{case Oct_Feb {condition month>=Oct .and. month<=Feb value 0.}
				 case Sep {condition month==Sep value 0.}
				 case mMar {condition month == Mar  .and. wyt_SAC_VA_(1) >= 4        select mMar from AmericanVA_GP where ID = 4}
				 case mApr {condition month == Apr  .and. WYT_Sac_Frcst >= 4         select mApr from AmericanVA_GP where ID = 4}
				 case mMay {condition month == May  .and. WYT_Sac_Frcst_dv(-1) >= 4  select mMay from AmericanVA_GP where ID = 4}
				 case otherwise {condition always value 0.}}
define GPmin_26N_NU4_ADDdv {alias GPmin_26N_NU4_ADD kind 'VA-GP-Multiplier' units 'NONE'}				 

define GPmin_26N_PU1_ADD	{case Oct_Feb {condition month>=Oct .and. month<=Feb value 0.}
				 case Sep {condition month==Sep value 0.}
				 case mMar {condition month == Mar  .and. wyt_SAC_VA_(1) >= 4         select mMar from AmericanVA_GP where ID = 5}
				 case mApr {condition month == Apr  .and. WYT_Sac_Frcst >= 4          select mApr from AmericanVA_GP where ID = 5}
				 case mMay {condition month == May  .and. WYT_Sac_Frcst_dv(-1) >= 4   select mMay from AmericanVA_GP where ID = 5}
				 case otherwise {condition always value 0.}}
define GPmin_26N_PU1_ADDdv {alias GPmin_26N_PU1_ADD kind 'VA-GP-Multiplier' units 'NONE'}

define GPmin_26N_PU2_ADD	{case Oct_Feb {condition month>=Oct .and. month<=Feb value 0.}
				 case Sep {condition month==Sep value 0.}
				 case mMar {condition month == Mar  .and. wyt_SAC_VA_(1) >= 4         select mMar from AmericanVA_GP where ID = 6}
				 case mApr {condition month == Apr  .and. WYT_Sac_Frcst >= 4          select mApr from AmericanVA_GP where ID = 6}
				 case mMay {condition month == May  .and. WYT_Sac_Frcst_dv(-1) >= 4   select mMay from AmericanVA_GP where ID = 6}
				 case otherwise {condition always value 0.}}
define GPmin_26N_PU2_ADDdv {alias GPmin_26N_PU2_ADD kind 'VA-GP-Multiplier' units 'NONE'}

define GPmin_26N_PU3_ADD	{case Oct_Feb {condition month>=Oct .and. month<=Feb value 0.}
				 case Sep {condition month==Sep value 0.}
				 case mMar {condition month == Mar  .and. wyt_SAC_VA_(1) >= 4         select mMar from AmericanVA_GP where ID = 7}
				 case mApr {condition month == Apr  .and. WYT_Sac_Frcst >= 4          select mApr from AmericanVA_GP where ID = 7}
				 case mMay {condition month == May  .and. WYT_Sac_Frcst_dv(-1) >= 4   select mMay from AmericanVA_GP where ID = 7}
				 case otherwise {condition always value 0.}}
define GPmin_26N_PU3_ADDdv {alias GPmin_26N_PU3_ADD kind 'VA-GP-Multiplier' units 'NONE'}

