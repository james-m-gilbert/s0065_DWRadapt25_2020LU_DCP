
!Estimate Daily flow conditions, bypass requirements and bounds on IF Diversion
!include 'IFDiversionCriteria_DailyOps.wresl'    Moved to main file to be included earlier

!Meet bypass criteria and cap the ND diversion
goal setndd { 
    lhs C_SAC048_ISF001
    case less20K {
        condition Q_SAC048corr <= 20000.
        rhs max(0.,min(ndd,(0.2827*Q_SAC048corr + 2671.3)))  !limiting summer ndd pumping for sweeping velocity constraints !reducing intercept by 200 cfs to cover most of the months with shortage in DSM2
    }
    case great20K {
        condition Q_SAC048corr > 20000.
        rhs max(0.,min(ndd,(0.1006*Q_SAC048corr + 6337.8)))  !limiting summer ndd pumping for sweeping velocity constraints !reducing intercept by 200 cfs to cover most of the months with shortage in DSM2
    }
    case other {
        condition always
        rhs max(0.,ndd)
        }
}

/*define nddlimitest {  !Moved to ExportEstimate1 files
   case less20K {
        condition Q_SAC048corr <= 20000.
 		value max(0.,min(ndd,(0.2827*Q_SAC048corr + 2671.3))) }
    case great20K {
        condition Q_SAC048corr > 20000.
        value max(0.,min(ndd,(0.1006*Q_SAC048corr + 6337.8))) }
 }*/	

goal limitNDD {D_SAC041_ISF001 < C_SAC048_ISF001 }

!Split capacity under bypass flow export cap between projects according to capacities
define SWPbypasscapshare {value max_IF_cap_SWP/(max_IF_cap_SWP + max_IF_cap_CVP)}
define CVPbypasscapshare {value max_IF_cap_CVP/(max_IF_cap_SWP + max_IF_cap_CVP)}
!Weighted so that one project can use the others share if it is not used
goal limitNDDSWP {
	lhs C_CAA003_SWP_IF + C_CAA003_CVP_IF
	rhs C_SAC048_ISF001 * SWPbypasscapshare
	lhs > rhs penalty 1200.
	lhs < rhs penalty 0.
}
goal limitNDDCVP {
	lhs C_DMC000_IF 
	rhs C_SAC048_ISF001 * CVPbypasscapshare
	lhs > rhs penalty 1200.
	lhs < rhs penalty 0.
}
define SWPbypasscapsharedv {alias SWPbypasscapshare kind 'debug' units 'cfs'}
define CVPbypasscapsharedv {alias CVPbypasscapshare kind 'debug' units 'cfs'}

! calculate excess flow from previous cycle as unrequired DO
! First calculate potential excess in NDOI_ADD_ANN, can happen erroneously in DELTA cycle when salinity is not controlling
! Could not get this working, so commented out
/*define ANNexcess {
	case nosalinitycontrol {
	condition max(JPcontrol, EMcontrol, RScontrol) < 0.5
		value NDOI_ADD_ANN[DELTA] }
	case otherwise {
	condition always
		value 0.}
}*/

!Need to check for surplus that is only available because of DCC NMFS BO export cut, this should not be diverted
define DCCBO_protected_surplus {
	case exportcut {
	condition abs(EXPORTACTUALTD[DELTA] - NMFS_MAXEXPDCCDV[DELTA]) < 0.1 
		value max(0.,(NDOI_ADD_SWP[DELTA] + NDOI_ADD_CVP[DELTA]) - (NDOI_ADD_SWP[UPSTREAM] + NDOI_ADD_CVP[UPSTREAM]))
	}
	case otherwise {
	condition always 
	value 0.}
}

define DCCBO_protected_surplus_ {alias DCCBO_protected_surplus kind 'debug' units 'cfs'}

define ExcessDO    {value max(0.,NDOI_ADD[DELTA] - NDOI_ADD_ANN[DELTA] - DCCBO_protected_surplus)}
goal Excess_for_NDD1 {D_SAC041_ISF001_excess < ExcessDO}

define ExcessDOforNDD {alias ExcessDO kind 'debug' units 'cfs'}

!ensure that excess is actually taken (in some cases storage was being used instead)
goal Excess_for_NDD2 {D_SAC041_ISF001_excess = (NDOI_ADD_SWP[DELTA] + NDOI_ADD_CVP[DELTA]) - (NDOI_ADD_SWP + NDOI_ADD_CVP)}

/*define FourRiver_Index {
	value UNIMP_OROV + UNIMP_FOLS + UNIMP_YUBA + UNIMP_SRBB
}


define FourRiver_Index_dv {alias FourRiver_Index kind 'index' units 'taf'}


define bypassflow {value 0.23 * Pow(FourRiver_Index,1.47)}


define bypassflow_dv {alias bypassflow kind 'FLOW' units 'CFS'}


define Outflow_LFS_DO{
	case Mar {
	condition	month>=Mar .and. month<=May
	value bypassflow
	}
	case other {
	condition always
	value 0
	}
}

define Outflow_LFS_DOdv {alias Outflow_LFS_DO kind 'FLOW' units 'CFS'}

! In Apr-May only use NDD when outflow is > 29200
! Excess over 29200 that could be exported
define maxNDDexcessMarMay {value max(0., C_SAC017[DELTA] - Outflow_LFS_DO)}
goal MaintainDO {
	lhs D_SAC041_ISF001_excess
	case LowOutflow {
		condition month>=MAR .and. month<=MAY
		rhs maxNDDexcessMarMay
		lhs<rhs penalty 0} 
}
*/

! Only divert excess above 35,000 cfs in Mar-May 
define D_SAC041_ISF001_excess_criteria {
/*	case MarMay {
		condition month>=MAR .and. month<=MAY
		value 35000.
	}*/
	case other {
		condition always
		value 0.
	}
} 
define maxNDDexcess {value max(0.,NDOI[DELTA] - D_SAC041_ISF001_excess_criteria)}
goal MaintainDO {D_SAC041_ISF001_excess < maxNDDexcess}

define maxNDDexcessdv {alias maxNDDexcess kind 'debug' units 'cfs'}

! There is a small possibility that DO could increase due to a change in 
! operations of the DXC, which would limit exports and cause higher DO.  
! This goal accommodates that.  
/*goal Excess_for_NDD2 {
	lhs D_SAC041_ISF001_excess 
    rhs C406_chgndd
    lhs<rhs penalty 0
    lhs>rhs penalty 9999
}*/  !commented out for now since was preventing export in some months -TF

! Elective North Delta Diversion would be the model's decision to export
! water at D_SAC041_ISF001 instead of the through-delta pathway, or to pull water from
! storage that otherwise could not have been exported due to restrictions.

! Elective switch from TD to ND diversion will occur only in situations where there is a carriage water benefit 
! Additional supplies from the carriage water benefit can be exported or backed up into storage
! Exports will occur when there is capacity at the pumps and San Luis is below rule, otherwise will be backed up into storage 
! Ideally benefits should be shared according to COA UWFE sharing formula, but in many cases this is not possible because of lack of export capacity
! and/or lack of ability to back off on releases.  If one project cannot make use of its share of benefits, the other one will get them
! Only allow shift in cases where salinity requirements are controlling outflow in DELTA cycle, since that is the only situation where there could be a carriage water benefit
! Added second case to cover situation when small amounts of excess can be taken, leaving salinity controlling, then shift can happen
! Logic also excludes situation when there is water in the ANN variable that is really surplus, which can happen when salinity is not controlling
define SurpDivest {value max(0.,min(nddlimitest,EIexpctrl[DELTA] - TOTAL_EXP_A[DELTA]))}

! Figure out if the DCC export cap changes, if so will deactivate shifting, since it is hard to get the operation right in this situation (which is very rare).
define DCCexpcapchanged {
	case changed {
	condition abs(NMFS_MaxExp_DCC - NMFS_MaxExpDCCDV[DELTA]) > 0.5 
		value 1.}
	case otherwise {
	condition always
		value 0.}
}

define TDshift {
	case salinityctrl {
      condition NDOI_ADD_ANN[DELTA] > 0.1 .and. (NDOI_ADD_CVP[DELTA] + NDOI_ADD_SWP[DELTA]) < 0.1 .and. max(JPcontrol, EMcontrol, RScontrol) > 0.5 .and. DCCexpcapchanged < 0.5 .and. (JonesIFSwitch > 0.5 .or. BanksIFSwitch > 0.5)
      value 1.}
/* 	case salinityctrlpossible { !less common case when some excess is taken then can shift to salinity control
      condition NDOI_ADD_ANN[DELTA] > 0.1 .and. (NDOI_ADD_CVP[DELTA] + NDOI_ADD_SWP[DELTA]) > 0.1 .and. max(JP_MRDO[DELTA],EM_MRDO[DELTA],RS_MRDO_1[DELTA],RS_MRDO_2[DELTA],RS_MRDO_3[DELTA]) > NDOI_MIN[DELTA] .and. ExcessDO < SurpDivest
      value 1.}*/  ! deactivated for now since this operation doesn't always work right
    case otherwise {
      condition always
      value 0.}
}

/* no longer used
 * define DCCexpcapchg {
	case nocap {
	condition NMFS_MaxExp_DCC == 999999.
		value 0.}
	case otherwise {
	condition always
		value max(0.,(ExportActualTD[DELTA] - NMFS_MaxExp_DCC) - min(nddlimitest,NDOI_ADD[DELTA]))}  !Estimate change in exports is exports from last cycle - DCC limit, but adjusted for estimate of ndd pumping (since this volume of the decrease can be shifted)
}*/

goal Shiftlimit {
	lhs D_SAC041_ISF001_elect_tdnd 
	case nosalinityctrl {
	  condition TDshift < 0.5
	  rhs 0 
	  lhs<rhs penalty 999999.
	  lhs>rhs penalty 999999.}
}
!If same criteria apply hold NDOI_ADD_ANN constant (sometimes it seems to shift), unless DCC exp cap changed
goal salinityflowhold {
	lhs NDOI_ADD_ANN 
	case nosalinityctrl {
	  condition TDshift < 0.5 .and. DCCexpcapchanged < 0.5
	  rhs NDOI_ADD_ANN[DELTA] 
	  lhs<rhs penalty 999999.
	  lhs>rhs penalty 999999.}
}
! And also hold TD exports the same
goal CAATDhold {
	lhs C_CAA003_TD
	case nosalinityctrl {
	  condition TDshift < 0.5 .and. DCCexpcapchanged < 0.5
	  rhs C_CAA003_TD[DELTA] 
	  lhs<rhs penalty 999999.
	  lhs>rhs penalty 999999.}
}
goal CAATDEXP1hold {
	lhs C_CAA003_EXP1_TD
	case nosalinityctrl {
	  condition TDshift < 0.5 .and. DCCexpcapchanged < 0.5
	  rhs C_CAA003_EXP1_TD[DELTA] 
	  lhs<rhs penalty 999999.
	  lhs>rhs penalty 999999.}
}
goal CAATDEXP2hold {
	lhs C_CAA003_EXP2_TD
	case nosalinityctrl {
	  condition TDshift < 0.5 .and. DCCexpcapchanged < 0.5
	  rhs C_CAA003_EXP2_TD[DELTA] 
	  lhs<rhs penalty 999999.
	  lhs>rhs penalty 999999.}
}
goal DMCTDhold {
	lhs C_DMC000_TD 
	case nosalinityctrl {
	  condition TDshift < 0.5 .and. DCCexpcapchanged < 0.5
	  rhs C_DMC000_TD[DELTA] 
	  lhs<rhs penalty 999999.
	  lhs>rhs penalty 999999.}
}

goal Elect_TDNDset  {D_SAC041_ISF001_elect_tdnd = C_CAA003_SWP_IF_ElectT + C_DMC000_IF_electT} 

!Reduction in carriage water due to shift from TD to NDD has to balance out with increase in exports or backed up storage
goal CarriageWaterbalance  {
	lhs NDOI_ADD_ANN[DELTA] - NDOI_ADD_ANN 
	case TDshift {
	condition TDshift > 0.5  
	rhs D_SAC041_ISF001_elect_tdnd - ((ExportActualTD[DELTA] - ExportActualTD)) !This is difference between shifted water NDD and change in exports TD, which will be = carriage water savings that are exported
								  + swpds[delta] - swpds + stored_fs - stored_fs[delta]		   !Next few terms account for backed up water into storage
	                              + shads[delta] - shads + stored_ss_sha - stored_ss_sha[delta]
	                              + folds[delta] - folds + stored_ss_fol - stored_ss_fol[delta]
	                              + whssw[delta] - whssw
	lhs<rhs penalty 999999.
	lhs>rhs penalty 999999.
}}

!Had some issues with Jersey Point outflow req for salinity not matching ANN outflow, so keep these consistent
goal manageoutflow {
	lhs NDOI_ADD_ANN[DELTA] - NDOI_ADD_ANN
	case JPcontrol {
	condition JPcontrol > 0.5 .and. TDshift > 0.5
		rhs JP_MRDO[DELTA] - JP_MRDO
		lhs>rhs penalty 999999.
		lhs<rhs penalty 999999.	
	}}

!Goals to prevent storage withdrawals from increasing, so only change in storage will be backing up carriage water benefits that can't be exported
goal Shastanostoragedec {shads < shads[delta]}
goal Folsomnostoragedec {folds < folds[delta]}
goal Orovillenostoragedec {swpds < swpds[delta]}
goal Whiskeytownnostoragedec {whssw < whssw[delta]}
goal Storedfsnostorinc {stored_fs > stored_fs[delta]}
goal Storedssshanostorinc {stored_ss_sha > stored_ss_sha[delta]}
goal Storedssfolnostorinc {stored_ss_fol > stored_ss_fol[delta]}

!Split carriage water benefits between projects.  Not too large a penalty, so benefits that cannot be used by one project can still go to the other project 
goal CarriageWatersplitSWP  {
	lhs (NDOI_ADD_ANN[DELTA] - NDOI_ADD_ANN) * SWP_Share[DELTA]
	case TDshift {
	condition TDshift > 0.5
	rhs C_CAA003_SWP - C_CAA003_SWP[DELTA] + swpds[delta] - swpds 
	lhs<rhs penalty 100.
	lhs>rhs penalty 100.
}}
goal CarriageWatersplitCVP  {
	lhs (NDOI_ADD_ANN[DELTA] - NDOI_ADD_ANN) * CVP_Share[DELTA]
	case TDshift {
	condition TDshift > 0.5
	rhs C_DMC000 - C_DMC000[DELTA] + shads[delta] - shads
									 + folds[delta] - folds
	                                 + whssw[delta] - whssw
	lhs<rhs penalty 100.
	lhs>rhs penalty 100.
}}

!For both projects the preferred use of CW benefits is to export them, weight (using negative penalty) here is to override the difference between NOD storage and San Luis when above rule curve.
goal CVPexportpreference {
	lhs C_DMC000 - C_DMC000[DELTA]
	case TDshift {
	condition TDShiftest > 0.5 .and. DCCexpcapchanged < 0.5
	rhs 0  
	lhs>rhs penalty -50.}
	}
goal SWPexportpreference {
	lhs C_CAA003_SWP - C_CAA003_SWP[DELTA]
	case TDshift {
	condition TDShiftest > 0.5 .and. DCCexpcapchanged < 0.5 
	rhs 0  
	lhs>rhs penalty -50.}
	}

!For CVP put backed up carriage water in Folsom first, but limit backed 120 cfs, then rest goes in Shasta, this is to limit the affect on flows in the American River.
goal CVPstoragepreference {
	lhs (FOLDS[DELTA] - FOLDS)
	case TDshift {
	condition TDShiftest > 0.5
	rhs 240.  
	lhs>rhs constrain
	lhs<rhs penalty 50.}
	}

!CVP use of the NDD is not allowed in months when an ITP export cut is expected
!goal noCVPNDD {
!	lhs C_DMC000_IF
!	case cutexpected {
!	condition Alt2BSWPExpCut > 0.5
!		rhs 0.
!		lhs<rhs constrain
!		lhs>rhs constrain
!}}

!Split reduction in TD exports in same proportion as TD exports in cycle before shift
!Will not change final exports or carriage water benefits, just for accounting, can be overriden by other capacity limits/rules if necessary
!Only used if both projects are using the NDD
define SWPshareshift {
	case SWPshift {
	condition SWPTDShiftSwitch > 0.5 .and. C_CAA003_SWP_TD[DELTA] + C_DMC000_TD[DELTA] > 0.5 .and. TDshift > 0.5
	value (C_CAA003_SWP_TD[DELTA] * SWPTDShiftSwitch) / (C_CAA003_SWP_TD[DELTA] * SWPTDShiftSwitch + C_DMC000_TD[DELTA] * CVPTDShiftSwitch+0.001)
	}
	case otherwise {
	condition always
	value 0.
	}
}
define CVPshareshift {
	case CVPshift {
	condition CVPTDShiftSwitch > 0.5 .and. C_CAA003_SWP_TD[DELTA] + C_DMC000_TD[DELTA] > 0.5 .and. TDshift > 0.5
	value (C_DMC000_TD[DELTA] * CVPTDShiftSwitch) / (C_CAA003_SWP_TD[DELTA] * SWPTDShiftSwitch + C_DMC000_TD[DELTA] * CVPTDShiftSwitch+0.001)
	}
	case otherwise {
	condition always
	value 0.
	}
}
goal splitshiftSWP {
	lhs SWPshareshift * (EXPORTACTUALTD[DELTA] - EXPORTACTUALTD) 
	case splitshift {
		condition BanksIFSwitch > 0.5 .and. JonesIFSwitch > 0.5 .and. TDshift > 0.5
	rhs C_CAA003_SWP_TD[DELTA] - C_CAA003_SWP_TD
	lhs<rhs penalty 100.
	lhs>rhs penalty 100.
}}
goal splitshiftCVP {
	lhs CVPshareshift * (EXPORTACTUALTD[DELTA] - EXPORTACTUALTD) 
	case splitshift {
		condition BanksIFSwitch > 0.5 .and. JonesIFSwitch > 0.5 .and. TDshift > 0.5
	rhs C_DMC000[DELTA] - C_DMC000
	lhs<rhs penalty 100.
	lhs>rhs penalty 100.
}}

! Reduce shift if there is an expectation of releases from storage to go through the North Delta Diversion.  
! Otherwise too much of a shift will prevent the storage release
! Apply July-Sept only since that is normally when storage releases happen.
! Removing this since shifting is now a lot less than the original model, and estimate below needs to be re-formulated for this to make sense.
! May want to reinstate this at some point
/*define TDshiftlimit {value max(0., nddlimitest - Oro_stor_release_est * SWPTDShiftSwitch - CVP_stor_release_est * CVPTDShiftSwitch) }
goal Elect_TDND1 {  
	lhs D_SAC041_ISF001_elect_tdnd
	case JulSep {
	  condition month >= Jul .and. month <= Sep
	  rhs TDshiftlimit
	  lhs<rhs penalty 0.
	  lhs>rhs penalty 99999.}}
*/
!Estimate of possible shift from Delta to NDD, for checking purposes, needs to be improved
!define Elect_TDNDest {value min(nddlimitest, C_SAC048[DELTA] - C_SAC048_BYPASS[DELTA], C_CAA003_SWP[DELTA] + C_DMC000[DELTA])}
!define Elect_TDNDestdv {alias Elect_TDNDest kind 'debug' units 'cfs'}

! Any change in flow at C_SAC048 should be either a reduction due to lower carriage water or
! TD export that has become ND or an increase due to add'l storage withdrawal.  There
! should be a direct relationship between change in total storage withdrawal and change
! in flow at C_SAC048. Both sides in the goal below should be either negative or positive.
! This goal will also keep other NOD ops from changing.  
! Have to include stored_fs and stored_ss terms in this cycle to allow for backing up of carriage water benefits classified as unused share
goal C_SAC048_mod {C_SAC048 - C_SAC048[DELTA] = swpds - swpds[delta] + stored_fs[delta] - stored_fs 
	                              + shads - shads[delta] + stored_ss_sha[delta] - stored_ss_sha
	                              + folds - folds[delta] + stored_ss_fol[delta] - stored_ss_fol
	                              + whssw - whssw[delta]
	                              + SP_SAC083_YBP037 - SP_SAC083_YBP037[delta]
	                              + SP_SAC066_YBP020 - SP_SAC066_YBP020[delta]}

! Applying switches to turn on or off different sources
goal switchC_CAA003_SWP_IF_excess {C_CAA003_SWP_IF_excess < SWPExcessSwitch * 99999.}
goal switchC_DMC000_IF_excess {C_DMC000_IF_excess < CVPExcessSwitch * 99999.}  
goal switchC_CAA003_CVP_IF_excess {C_CAA003_CVP_IF_excess = 0.}  !This can happen in the wheeling cycles

goal switchC_CAA003_SWP_IF_ElectT {C_CAA003_SWP_IF_ElectT < SWPTDShiftSwitch * 99999.}
goal switchC_DMC000_IF_ElectT {C_DMC000_IF_ElectT < CVPTDShiftSwitch * 99999.}  

goal switchC_CAA003_SWP_ElectS {C_CAA003_SWP_IF_ElectS = 0.}  !Storage releases don't happen until the NDD2 cycle  
goal switchC_DMC000_IF_ElectS {C_DMC000_IF_ElectS  = 0.}  !Storage releases don't happen until the NDD2 cycle  
goal switchC_CAA003_CVP_IF_ElectS {C_CAA003_CVP_IF_ElectS = 0.}  !This can happen in the wheeling cycles

!Preference for TD pumping up to 3,000 cfs in summer.
goal PreferTD {
	lhs C_DMC000_TD + C_CAA003_TD
	case JulSep {
		condition month>=JUL .and. month<=SEP
		rhs min(3000., C_DMC000_TD[delta] + C_CAA003_TD[delta])
		lhs<rhs penalty 1002 ! this has to overcome the negative carriage water penalty
		lhs>rhs penalty 0
	}
}

