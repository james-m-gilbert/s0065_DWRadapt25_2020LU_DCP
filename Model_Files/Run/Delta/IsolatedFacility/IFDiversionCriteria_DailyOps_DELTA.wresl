define C_SAC048_chgndd {alias C_SAC048[delta] - C_SAC048 kind 'debug' units 'cfs'}

define nddlimitestdv {alias nddlimitest kind 'debug' units 'cfs'}

! ********************************************************************
! Control dedicated use of Banks capacity for CVP with delta conveyance
! Enable use up to specified capacity, but only if Jones is maxed and 
! there is space in CVPSL to put it.
! *** Not currently implemented in model

define CVP_BanksMaxND_Est {
	case DedCapForCVP {
		condition S_SLUIS_SWPlevel5[DELTA]<S_SLUIS_SWPlevel5-1.
		value max(0., BanksMaxAllowCVPIF - (4600.-C_DMC000[DELTA]))}
	case otherwise {
		condition always
		value 0. }
}
define CVP_BanksMaxND_EstDV {alias CVP_BanksMaxND_Est kind 'ndd-debug' units 'cfs'}

goal BanksDedCapWithNDD1 {C_CAA003_CVPDED_IF < BanksMaxAllowCVPIF}
goal BanksDedCapWithNDD2 {
	lhs C_CAA003_CVPDED_IF 
	rhs CVP_BanksMaxND_Est
	lhs<rhs penalty 3000
}

!Fixing some variables that can shift in this cycle
goal fixNBA {D_BKR004_NBA009 = D_BKR004_NBA009[DELTA]}
goal fixKESWICKmif2 {C_KSWCK_MIF2 = C_KSWCK_MIF2[DELTA]}

