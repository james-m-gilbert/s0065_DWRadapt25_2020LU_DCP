/*Initial Pulse Protection:
****************************************
Previous comments:
Low level pumping maintained through the initial pulse period. For the purpose of monitoring, the
initiation of the pulse is defined by the following criteria:
(1) Wilkins Slough flow changing by more than 45% over a five day period and
(2) flowgreater than 12,000 cfs.

Trigger Definition:
0 = Not in pulse period
1 = In pulse period

Updated comments:
Low level pumping maintained through the initial pulse period.
For the purpose of modeling, the pulse is defined by the following criteria:
	Turning on - TPulseON_Ddd=1 when
		(1) Wilkins Slough flow changing by more than 45% over a five day period and
		(2) flowgreater than 12,000 cfs.
	Turning off - TPulseOFF1_Ddd=1 when
		(1) flows decrease for 5 consecutive days, or
		(2) Wilkins Slough returns to prepulse flows (flow on first day of 5-day increase),
	Turning off - TPulseOFF2_Ddd=1 when
		(1)flows are greater than 20,000 cfs for 10 consecutive days. (DH20130301 BDCP code used flows at Hood. Should have been Wilkins Slough per Tucker (NMFS), so simply replaced "byp_LLP_d" with "Q_SAC097_" in the definition of TPulseOFF2_Dnn
PSwitch_Ddd=1 when the pulse is occuring (only)
PCSwitch_Ddd=1 once a pulse has occurred. It keeps track of two periods - Oct1-Nov30 and Dec1-Sep30. That is, it is re-initialized to 0 on Oct 1st & Dec 1st.
		This variable is used to ensure that no more than one pulse is registered in either periods, i.e., there can be one in each if the criteria herein is satisfied.
		If the first pulse occurs in October,  then PCSwitch_D31dv = 1 for Oct and Nov.       Dec and each month onward will have PCSwitch_D31dv=0 unless another pulse occurs in one of those months.
		If the first pulse occurs in November, then PCSwitch_D31dv = 0 for Oct & = 1 for Nov. Dec and each month onward will have PCSwitch_D31dv=0 unless another pulse occurs in one of those months.
		If the first pulse occurs in December, then PCSwitch_D31dv = 0 for Oct & Nov.         Dec and each month onward will have PCSwitch_D31dv=1.
		If the first pulse occurs in January,  then PCSwitch_D31dv = 0 for Oct, Nov & Dec.    Jan and each month onward will have PCSwitch_D31dv=1.
		etc.

After pulse period has ended, operations will return to the bypass flow table (SubTable A).= post-pulse Level 1
These parameters are for modeling purposes, actual operations will be based on real-time monitoring of fish movement.
If the first flush begins before Dec 1, May bypass criteria must be initiated following first flush and the second pulse period will have the same protective operation.
DH note:  Code reflecting the previous line has eluded me.

NOTE 091923 TF: Code has now been adjusted to implement the following:
(1) Wilkins Slough flow threshold is now 10,500 cfs
(2) All pulses are protected
(3) LLP no longer limied to 900 cfs
(4) During pulse protection, diversion can be > LLP if bypass flows can still be maintained at 35,000 cfs 

*************************************** */

define TPulseON_D31dv {std kind 'TRIGGER' units 'none'}
define PQday1_d31dv     {std kind 'TRIGGER' units 'none'}
define TPulseOFF1_D31dv {std kind 'TRIGGER' units 'none'}
define TPulseOFF2_D31dv {std kind 'TRIGGER' units 'none'}
define PCSwitch_D31dv   {std kind 'TRIGGER' units 'none'}
define PSwitch_D31dv    {std kind 'TRIGGER' units 'none'}

!Day1
define TPulseON_D1    {
	case start    {condition month==OCT value 0. }
	case June1    {condition month==JUN value 0.}  !Need to fix June 1 as level 1 with count of days > 20000 = 0
	case trigON1d31 {condition daysinprv == 31 .and. Q_SAC097_1/max(0.1,Q_SAC097_31dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON1d30 {condition daysinprv == 30 .and. Q_SAC097_1/max(0.1,Q_SAC097_30dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON1d29 {condition daysinprv == 29 .and. Q_SAC097_1/max(0.1,Q_SAC097_29dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON1d28 {condition daysinprv == 28 .and. Q_SAC097_1/max(0.1,Q_SAC097_28dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON2d31 {condition daysinprv == 31 .and. Q_SAC097_1/max(0.1,Q_SAC097_30dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON2d30 {condition daysinprv == 30 .and. Q_SAC097_1/max(0.1,Q_SAC097_29dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON2d29 {condition daysinprv == 29 .and. Q_SAC097_1/max(0.1,Q_SAC097_28dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON2d28 {condition daysinprv == 28 .and. Q_SAC097_1/max(0.1,Q_SAC097_27dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON3d31 {condition daysinprv == 31 .and. Q_SAC097_1/max(0.1,Q_SAC097_29dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON3d30 {condition daysinprv == 30 .and. Q_SAC097_1/max(0.1,Q_SAC097_28dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON3d29 {condition daysinprv == 29 .and. Q_SAC097_1/max(0.1,Q_SAC097_27dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON3d28 {condition daysinprv == 28 .and. Q_SAC097_1/max(0.1,Q_SAC097_26dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON4d31 {condition daysinprv == 31 .and. Q_SAC097_1/max(0.1,Q_SAC097_28dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON4d30 {condition daysinprv == 30 .and. Q_SAC097_1/max(0.1,Q_SAC097_27dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON4d29 {condition daysinprv == 29 .and. Q_SAC097_1/max(0.1,Q_SAC097_26dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON4d28 {condition daysinprv == 28 .and. Q_SAC097_1/max(0.1,Q_SAC097_25dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON5d31 {condition daysinprv == 31 .and. Q_SAC097_1/max(0.1,Q_SAC097_27dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON5d30 {condition daysinprv == 30 .and. Q_SAC097_1/max(0.1,Q_SAC097_26dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON5d29 {condition daysinprv == 29 .and. Q_SAC097_1/max(0.1,Q_SAC097_25dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case trigON5d28 {condition daysinprv == 28 .and. Q_SAC097_1/max(0.1,Q_SAC097_24dv(-1)) > 1.45 .and. Q_SAC097_1 > 10500.0 value 1. }
	case other    {condition always value 0. }   }
define TPulseON_d1dv  {alias TPulseON_d1 kind 'TRIGGER' units 'NONE'}
define PQday1_d1      {
	case reset    {condition month==OCT  value  0.}
	case count31  {condition daysinprv == 31  .and.	int(PSwitch_d31dv(-1)) ==0 .and. int(TPulseON_d1) ==1 	value Q_SAC097_28dv(-1)}
	case count30  {condition daysinprv == 30  .and.	int(PSwitch_d31dv(-1)) ==0 .and. int(TPulseON_d1) ==1 	value Q_SAC097_27dv(-1)}
	case count29  {condition daysinprv == 29  .and.	int(PSwitch_d31dv(-1)) ==0 .and. int(TPulseON_d1) ==1 	value Q_SAC097_26dv(-1)}
	case count28  {condition daysinprv == 28  .and.	int(PSwitch_d31dv(-1)) ==0 .and. int(TPulseON_d1) ==1 	value Q_SAC097_25dv(-1)}
	case counton  {condition			int(PSwitch_d31dv(-1)) ==1                            	value PQday1_d31dv(-1)}	! Preserve value already established.
	case nopulse  {condition 			int(PSwitch_d31dv(-1)) ==0 .and. int(TPulseON_d1) ==0 	value 0.} 		! No pulse
	case other    {condition always 									value 0.} }		! Shouldn't get here.
define PQday1_d1dv    {alias PQday1_d1  kind 'TRIGGER' units 'NONE'}
define TPulseOFF1_D1  {
	case start    {condition month==OCT value 0. }
	case June1    {condition month==JUN value 1.}  !Need to fix June 1 as level 1 with count of days > 20000 = 0
 	case trigOFF1 {condition int(TPulseON_D31dv(-1))==1 .and. daysinprv == 31 .and. Q_SAC097_1 	 < Q_SAC097_31dv(-1) .and.  Q_SAC097_31dv(-1) < Q_SAC097_30dv(-1) .and. Q_SAC097_30dv(-1) < Q_SAC097_29dv(-1) .and.
 	                                						Q_SAC097_29dv(-1) < Q_SAC097_28dv(-1) .and.  Q_SAC097_28dv(-1) < Q_SAC097_27dv(-1) .or.  Q_SAC097_1 <= PQday1_d1 value 1. }
 	case trigOFF2 {condition int(TPulseON_D31dv(-1))==1 .and. daysinprv == 30 .and. Q_SAC097_1 	 < Q_SAC097_30dv(-1) .and.  Q_SAC097_30dv(-1) < Q_SAC097_29dv(-1) .and. Q_SAC097_29dv(-1) < Q_SAC097_28dv(-1) .and.
 	                                						Q_SAC097_28dv(-1) < Q_SAC097_27dv(-1) .and.  Q_SAC097_27dv(-1) < Q_SAC097_26dv(-1) .or.  Q_SAC097_1 <= PQday1_d1 value 1. }
 	case trigOFF3 {condition int(TPulseON_D31dv(-1))==1 .and. daysinprv == 29 .and. Q_SAC097_1 	 < Q_SAC097_29dv(-1) .and.  Q_SAC097_29dv(-1) < Q_SAC097_28dv(-1) .and. Q_SAC097_28dv(-1) < Q_SAC097_27dv(-1) .and.
 	                                						Q_SAC097_27dv(-1) < Q_SAC097_26dv(-1) .and.  Q_SAC097_26dv(-1) < Q_SAC097_25dv(-1) .or.  Q_SAC097_1 <= PQday1_d1 value 1. }
 	case trigOFF4 {condition int(TPulseON_D31dv(-1))==1 .and. daysinprv == 28 .and. Q_SAC097_1 	 < Q_SAC097_28dv(-1) .and.  Q_SAC097_28dv(-1) < Q_SAC097_27dv(-1) .and. Q_SAC097_27dv(-1) < Q_SAC097_26dv(-1) .and.
 	                                						Q_SAC097_26dv(-1) < Q_SAC097_25dv(-1) .and.  Q_SAC097_25dv(-1) < Q_SAC097_24dv(-1) .or.  Q_SAC097_1 <= PQday1_d1 value 1. }
 	case other    {condition always value 0. }   }
define TPulseOFF1_d1dv{alias TPulseOFF1_d1 kind 'TRIGGER' units 'NONE'}
define TPulseOFF2_D1  {
	case start    {condition month==OCT value 0.}
	case June    {condition month==JUN value 1.}  !Fix so no pulses possible in June
	case trigOFF1 {condition daysinprv==31  .and. Q_SAC097_1 > 20000. .and. Q_SAC097_31dv(-1) > 20000. .and. Q_SAC097_30dv(-1) > 20000. .and. Q_SAC097_29dv(-1) > 20000. .and. Q_SAC097_28dv(-1) > 20000. .and. Q_SAC097_27dv(-1) > 20000. .and. Q_SAC097_26dv(-1) > 20000. .and. Q_SAC097_25dv(-1) > 20000. .and. Q_SAC097_24dv(-1) > 20000. .and. Q_SAC097_23dv(-1) > 20000. value 1. }
	case trigOFF2 {condition daysinprv==30  .and. Q_SAC097_1 > 20000. .and. Q_SAC097_30dv(-1) > 20000. .and. Q_SAC097_29dv(-1) > 20000. .and. Q_SAC097_28dv(-1) > 20000. .and. Q_SAC097_27dv(-1) > 20000. .and. Q_SAC097_26dv(-1) > 20000. .and. Q_SAC097_25dv(-1) > 20000. .and. Q_SAC097_24dv(-1) > 20000. .and. Q_SAC097_23dv(-1) > 20000. .and. Q_SAC097_22dv(-1) > 20000. value 1. }
	case trigOFF3 {condition daysinprv==29  .and. Q_SAC097_1 > 20000. .and. Q_SAC097_29dv(-1) > 20000. .and. Q_SAC097_28dv(-1) > 20000. .and. Q_SAC097_27dv(-1) > 20000. .and. Q_SAC097_26dv(-1) > 20000. .and. Q_SAC097_25dv(-1) > 20000. .and. Q_SAC097_24dv(-1) > 20000. .and. Q_SAC097_23dv(-1) > 20000. .and. Q_SAC097_22dv(-1) > 20000. .and. Q_SAC097_21dv(-1) > 20000. value 1. }
	case trigOFF4 {condition daysinprv==28  .and. Q_SAC097_1 > 20000. .and. Q_SAC097_28dv(-1) > 20000. .and. Q_SAC097_27dv(-1) > 20000. .and. Q_SAC097_26dv(-1) > 20000. .and. Q_SAC097_25dv(-1) > 20000. .and. Q_SAC097_24dv(-1) > 20000. .and. Q_SAC097_23dv(-1) > 20000. .and. Q_SAC097_22dv(-1) > 20000. .and. Q_SAC097_21dv(-1) > 20000. .and. Q_SAC097_20dv(-1) > 20000. value 1. }
	case other    {condition always value 0. }   }
define TPulseOFF2_d1dv{alias TPulseOFF2_d1 kind 'TRIGGER' units 'NONE'}
define PCSwitch_d1    {
	case reset    {condition month==OCT .or. month==DEC value  0.}
	case count    {condition int(TPulseON_d31dv(-1)) ==0  .and. int(TPulseON_d1) ==1 value 1.}
	case other    {condition always value  PCSwitch_d31dv(-1)}}
define PSwitch_d1     {
	case oct      {condition month==OCT value TpulseON_d1}
	case June1    {condition month==JUN value 0.}  !Need to fix June 1 as level 1 with count of days > 20000 = 0
	case outsidep {condition int(PSwitch_d31dv(-1)) ==0 value max (0.,TpulseON_d1)} ! PCSwitch keeps track if a pulse has already occurred.  If so (on same side of Dec 1st) then don't do pulse protection
	case insidep  {condition int(PSwitch_d31dv(-1)) ==1 value min (1-TpulseOFF1_d1, 1-TpulseOFF2_d1)}  ! Terminate pulse if either TPulseOFF criteria met.
	case other    {condition always value PSwitch_d31dv(-1)}}
define PSwitch_d1dv   {alias PSwitch_d1 kind 'TRIGGER' units 'NONE'}

!Day2
define TPulseON_D2      {
	case start      {condition month==OCT .and. int(wateryear)==1922 value 0.}
	case June    {condition month==JUN value 0.}  !Fix so no pulses possible in June
    	case trigON1d   {condition Q_SAC097_2/Q_SAC097_1 > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON2d31 {condition daysinprv == 31 .and. Q_SAC097_2/max(0.1,Q_SAC097_31dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON2d30 {condition daysinprv == 30 .and. Q_SAC097_2/max(0.1,Q_SAC097_30dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON2d29 {condition daysinprv == 29 .and. Q_SAC097_2/max(0.1,Q_SAC097_29dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON2d28 {condition daysinprv == 28 .and. Q_SAC097_2/max(0.1,Q_SAC097_28dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON3d31 {condition daysinprv == 31 .and. Q_SAC097_2/max(0.1,Q_SAC097_30dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON3d30 {condition daysinprv == 30 .and. Q_SAC097_2/max(0.1,Q_SAC097_29dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON3d29 {condition daysinprv == 29 .and. Q_SAC097_2/max(0.1,Q_SAC097_28dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON3d28 {condition daysinprv == 28 .and. Q_SAC097_2/max(0.1,Q_SAC097_27dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON4d31 {condition daysinprv == 31 .and. Q_SAC097_2/max(0.1,Q_SAC097_29dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON4d30 {condition daysinprv == 30 .and. Q_SAC097_2/max(0.1,Q_SAC097_28dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON4d29 {condition daysinprv == 29 .and. Q_SAC097_2/max(0.1,Q_SAC097_27dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON4d28 {condition daysinprv == 28 .and. Q_SAC097_2/max(0.1,Q_SAC097_26dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON5d31 {condition daysinprv == 31 .and. Q_SAC097_2/max(0.1,Q_SAC097_28dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON5d30 {condition daysinprv == 30 .and. Q_SAC097_2/max(0.1,Q_SAC097_27dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON5d29 {condition daysinprv == 29 .and. Q_SAC097_2/max(0.1,Q_SAC097_26dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case trigON5d28 {condition daysinprv == 28 .and. Q_SAC097_2/max(0.1,Q_SAC097_25dv(-1)) > 1.45 .and. Q_SAC097_2 > 10500.0 value 1. }
	case other      {condition always value 0. }   }
define TPulseON_d2dv  {alias TPulseON_d2 kind 'TRIGGER' units 'NONE'}
define PQday1_d2{
	case count31  {condition daysinprv == 31 .and. int(PSwitch_d1) ==0  .and. int(TPulseON_d2) ==1 	value Q_SAC097_29dv(-1)}
	case count30  {condition daysinprv == 30 .and. int(PSwitch_d1) ==0  .and. int(TPulseON_d2) ==1 	value Q_SAC097_28dv(-1)}
	case count29  {condition daysinprv == 29 .and. int(PSwitch_d1) ==0  .and. int(TPulseON_d2) ==1 	value Q_SAC097_27dv(-1)}
	case count28  {condition daysinprv == 28 .and. int(PSwitch_d1) ==0  .and. int(TPulseON_d2) ==1 	value Q_SAC097_26dv(-1)}
	case other    {condition always value  PQday1_d1}}
define PQday1_d2dv    {alias PQday1_d2  kind 'TRIGGER' units 'NONE'}
define TPulseOFF1_D2  {
	case start    {condition month==OCT .and. int(wateryear)==1922 value 0.}
	case June    {condition month==JUN value 1.}  !Fix so no pulses possible in June
 	case trigOFF1 {condition daysinprv == 31 .and.	Q_SAC097_2 	 < Q_SAC097_1 	    .and.  Q_SAC097_1 	    < Q_SAC097_31dv(-1) .and. Q_SAC097_31dv(-1) < Q_SAC097_30dv(-1) .and.
