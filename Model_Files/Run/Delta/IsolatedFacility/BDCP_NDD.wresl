! ******************************************************************************************************************************************************
!For Dec-May, bypass flow is determined by LLP calcs, so just subtract the LLP from the flow to get the bypass 
!For July-Nov, bypass flow is always based on Level 1 (since Levels 1, 2, and 3 are the same for these months in IFBypassFlows_vs_SAC)
!For June, uses Level 1, 2, 3 calculations, but further above Level is set = 1 on June 1, so can only be 1 or 2 in that month.  

define  NDD_bypass_1 {
    case DectoMay {condition month >= Dec .and. month <= May value Q_SAC048_1-LLP_d1 }  
    case JulytoNov {condition month >= Jul .or. month <= Nov select Level_I from IFBypassFlows_vs_SAC given Sac_Flow=Q_SAC048_1 use linear where month=month}
    case level1 {condition int(NDD_Level_d1)==1 select Level_I from IFBypassFlows_vs_SAC given Sac_Flow=Q_SAC048_1 use linear where month=month}
    case level2 {condition int(NDD_Level_d1)==2 select Level_II from IFBypassFlows_vs_SAC given Sac_Flow=Q_SAC048_1 use linear where month=month}
    case other  {condition always select Level_I from IFBypassFlows_vs_SAC given Sac_Flow=Q_SAC048_1 use linear where month=month}
}
define  NDD_bypass_2 {
    case DectoMay {condition month >= Dec .and. month <= May value Q_SAC048_2-LLP_d2 }  
    case JulytoNov {condition month >= Jul .or. month <= Nov select Level_I from IFBypassFlows_vs_SAC given Sac_Flow=Q_SAC048_2 use linear where month=month}
    case level1 {condition int(NDD_Level_d2)==1 select Level_I from IFBypassFlows_vs_SAC given Sac_Flow=Q_SAC048_2 use linear where month=month}
    case level2 {condition int(NDD_Level_d2)==2 select Level_II from IFBypassFlows_vs_SAC given Sac_Flow=Q_SAC048_2 use linear where month=month}
    case other  {condition always select Level_I from IFBypassFlows_vs_SAC given Sac_Flow=Q_SAC048_2 use linear where month=month}
}
