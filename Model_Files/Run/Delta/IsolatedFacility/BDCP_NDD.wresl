	case trigON2d28 {condition daysin == 28                                            value 0. }  ! If 28 days in the month, Q_SAC097_29 = 0. and the quotient in the next condition would have a divisor of 0.
	case trigON2d   {condition Q_SAC097_31/Q_SAC097_29 > 1.45 .and. Q_SAC097_31 > 10500.0 value 1. }
	case trigON3d   {condition Q_SAC097_31/Q_SAC097_28 > 1.45 .and. Q_SAC097_31 > 10500.0 value 1. }
	case trigON4d   {condition Q_SAC097_31/Q_SAC097_27 > 1.45 .and. Q_SAC097_31 > 10500.0 value 1. }
	case trigON5d   {condition Q_SAC097_31/Q_SAC097_26 > 1.45 .and. Q_SAC097_31 > 10500.0 value 1. }
	case other	{condition always value 0. }   }
!define TPulseON_d31dv {alias TPulseON_d31 kind 'TRIGGER' units 'NONE'}
goal setTRG31		{
	lhs TPulseON_D31dv
	case Mon31 	{condition daysin == 31 rhs TPulseON_D31}
	case Mon30 	{condition daysin == 30 rhs TPulseON_D30}
	case Mon29 	{condition daysin == 29 rhs TPulseON_D29}
	case Mon28 	{condition daysin == 28 rhs TPulseON_D28} }
define PQday1_d31	{
	case count 	{condition int(PSwitch_d30) ==0  .and. int(TPulseON_d31) ==1 value Q_SAC097_27}
	case other 	{condition always value  PQday1_d30}}
!define PQday1_d31dv {alias PQday1_d31 kind 'TRIGGER' units 'NONE'}
goal setPQday1_31 	{
	lhs PQday1_D31dv
	case Mon31 	{condition daysin == 31 rhs PQday1_d31}
	case Mon30 	{condition daysin == 30 rhs PQday1_d30}
	case Mon29 	{condition daysin == 29 rhs PQday1_d29}
	case Mon28 	{condition daysin == 28 rhs PQday1_d28} }
define TPulseOFF1_D31   {
 	case trigOFF	{condition Q_SAC097_31 < Q_SAC097_30 .and. Q_SAC097_30 < Q_SAC097_29 .and. Q_SAC097_29 < Q_SAC097_28 .and. Q_SAC097_28 < Q_SAC097_27 .and. Q_SAC097_27 < Q_SAC097_26 .or. Q_SAC097_31 <= PQday1_d31 value 1. }
 	case other  	{condition always value 0. }   }
!goal setTPOFF1_d31dv {TPulseOFF1_d31dv = TPulseOFF1_d31 }
goal setTRGOFF1_31 	{
	lhs TPulseOFF1_D31dv
	case June    {condition month==JUN rhs 1.}  !Fix so no pulses possible in June
	case Mon31 	{condition daysin == 31 rhs TPulseOFF1_D31}
	case Mon30 	{condition daysin == 30 rhs TPulseOFF1_D30}
	case Mon29 	{condition daysin == 29 rhs TPulseOFF1_D29}
	case Mon28 	{condition daysin == 28 rhs TPulseOFF1_D28} }
define TPulseOFF2_D31   {
	case June    {condition month==JUN value 1.}  !Fix so no pulses possible in June
	case trigOFF	{condition Q_SAC097_31 > 20000. .and.  Q_SAC097_30 > 20000. .and. Q_SAC097_29 > 20000. .and. Q_SAC097_28 > 20000. .and. Q_SAC097_27 > 20000. .and. Q_SAC097_26 > 20000. .and. Q_SAC097_25 > 20000. .and. Q_SAC097_24 > 20000. .and. Q_SAC097_23 > 20000. .and. Q_SAC097_22 > 20000. value 1. }
	case other  	{condition always value 0. }   }
! define TPulseOFF2_d31dv {alias TPulseOFF2_d31 kind 'TRIGGER' units 'NONE'}
goal setTRGOFF2_31 	{
	lhs TPulseOFF2_D31dv
	case Mon31 	{condition daysin == 31 rhs TPulseOFF2_D31}
	case Mon30 	{condition daysin == 30 rhs TPulseOFF2_D30}
	case Mon29 	{condition daysin == 29 rhs TPulseOFF2_D29}
	case Mon28 	{condition daysin == 28 rhs TPulseOFF2_D28} }
define PCSwitch_d31	{
	case count 	{condition int(TPulseON_d30) ==0  .and. int(TPulseON_d31) ==1 value 1.}
	case other	{condition always value  PCSwitch_d30}}
goal setPCSwitch_31	{
	lhs PCSwitch_D31dv
	case Mon31 	{condition daysin == 31 rhs PCSwitch_d31}
	case Mon30 	{condition daysin == 30 rhs PCSwitch_d30}
	case Mon29 	{condition daysin == 29 rhs PCSwitch_d29}
	case Mon28 	{condition daysin == 28 rhs PCSwitch_d28} }
define PSwitch_d31	{
	case outsidep 	{condition int(PSwitch_d30) ==0  value max (0., TpulseON_d31)}
	case insidep 	{condition int(PSwitch_d30) ==1  value min (1-TpulseOFF1_d31, 1-TpulseOFF2_d31)}
	case other	{condition always value  PSwitch_d30}}
!define PSwitch_d31dv {alias PSwitch_d31 kind 'TRIGGER' units 'NONE'}
goal setPSwitch_d31	{
	lhs PSwitch_D31dv
	case June    {condition month==JUN rhs 0.}  !Fix so no pulses possible in June
	case Mon31 	{condition daysin == 31 rhs PSwitch_D31}
	case Mon30 	{condition daysin == 30 rhs PSwitch_D30}
	case Mon29 	{condition daysin == 29 rhs PSwitch_D29}
	case Mon28 	{condition daysin == 28 rhs PSwitch_D28} }

define TPulseON {value TPulseON_d1+TPulseON_d2+TPulseON_d3+TPulseON_d4
       +TPulseON_d5+TPulseON_d6+TPulseON_d7+TPulseON_d8+TPulseON_d9
       +TPulseON_d10+TPulseON_d11+TPulseON_d12+TPulseON_d13+TPulseON_d14
       +TPulseON_d15+TPulseON_d16+TPulseON_d17+TPulseON_d18+TPulseON_d19
       +TPulseON_d20+TPulseON_d21+TPulseON_d22+TPulseON_d23+TPulseON_d24
       +TPulseON_d25+TPulseON_d26+TPulseON_d27+TPulseON_d28+TPulseON_d29
       +TPulseON_d30+TPulseON_d31}
define TPulseONdv {alias TPulseON kind 'TRIGGER' units 'NONE'}


/* Post-Pulse Operations:
***************************************
After initial flush(es), go to Level I post-pulse bypass rule (see SubTable A) until 15 total days of
bypass flows above 20,000 cfs. Then go to the Level II post-pulse bypass rule until 30 total days
of bypass flows above 20,000 cfs. Then go to the Level III post-pulse bypass rule.
*/

