    case range2 {condition (month >= Dec .and. month <= May) .and. Q_SAC048_2 >= range2*(1.+prc1) .and. Q_SAC048_2 < range3*(1.+prc2) value max(0., min(99999.,Q_SAC048_2 -range2 ,prc2* Q_SAC048_2 ))} 
    case range3 {condition (month >= Dec .and. month <= May) .and. Q_SAC048_2 >= range3*(1.+prc2) value max(0., min(99999.,Q_SAC048_2 -range3 ,prc3* Q_SAC048_2 ))} 
    case range1_ {condition  Q_SAC048_2 > range1  .and. Q_SAC048_2 < range2     value   max(0., min(99999.,Q_SAC048_2 -range1 ,prc1* Q_SAC048_2)) } !Remaining condition for June-November, pulled from NDD_t1
    case range2_ {condition  Q_SAC048_2 >= range2    value   max(0., min(99999.,Q_SAC048_2 -range1 ,prc2* Q_SAC048_2 ))} !Remaining condition for June-November,  pulled from NDD_t1
