

!Initial operations Criteria
/*
Constant Low-Level Pumping (Dec-Jun):
****************************************
Diversions up to 6% of river flow for flows greater than 5,000 cfs. No 900 cfs cap.
*/

define daysinprv {value daysindv(-1)}

define range1 {select range1 from NDD_t1 where month = month }
define prc1   {select prc1   from NDD_t1 where month = month }

define range2 {select range2 from NDD_t1 where month = month }
define prc2   {select prc2   from NDD_t1 where month = month }

define range3 {select range3 from NDD_t1 where month = month } 
define prc3   {select prc3   from NDD_t1 where month = month } 

define LLP_d1 {
    case nodiversions {condition (month >= Dec .and. month <= May) .and. Q_SAC048_1 < range1  value 0. }
    case range1 {condition (month >= Dec .and. month <= May) .and. Q_SAC048_1 >= range1 .and. Q_SAC048_1 < range2*(1.+prc1) value max(0., min(99999.,Q_SAC048_1 -range1 ,prc1* Q_SAC048_1)) } 
    case range2 {condition (month >= Dec .and. month <= May) .and. Q_SAC048_1 >= range2*(1.+prc1) .and. Q_SAC048_1 < range3*(1.+prc2) value max(0., min(99999.,Q_SAC048_1 -range2 ,prc2* Q_SAC048_1 ))} 
    case range3 {condition (month >= Dec .and. month <= May) .and. Q_SAC048_1 >= range3*(1.+prc2) value max(0., min(99999.,Q_SAC048_1 -range3 ,prc3* Q_SAC048_1 ))} 
    case range1_ {condition  Q_SAC048_1 > range1  .and. Q_SAC048_1 < range2     value   max(0., min(99999.,Q_SAC048_1 -range1 ,prc1* Q_SAC048_1)) } !Remaining condition for June-November, pulled from NDD_t1
    case range2_ {condition  Q_SAC048_1 >= range2    value   max(0., min(99999.,Q_SAC048_1 -range1 ,prc2* Q_SAC048_1 ))} !Remaining condition for June-November,  pulled from NDD_t1
    case other  {condition always value 0. }   } !Remaining condition for June-November

