
!Estimate Daily flow conditions, bypass requirements and bounds on IF Diversion
!include 'IFDiversionCriteria_DailyOps.wresl'  Moved to main file to be included earlier

!Meet bypass criteria and cap the ND diversion
goal setndd { !Used soft penalties in this cycle because of problems with infeasibilities
    lhs C_SAC048_ISF001
    case less20K {
        condition Q_SAC048corr <= 20000.
        rhs max(0.,min(ndd,(0.2827*Q_SAC048corr + 2671.3)))  !limiting summer ndd pumping for sweeping velocity constraints !reducing intercept by 200 cfs to cover most of the months with shortage in DSM2
    }
    case great20K {
        condition Q_SAC048corr > 20000.
        rhs max(0.,min(ndd,(0.1006*Q_SAC048corr + 6337.8)))  !limiting summer ndd pumping for sweeping velocity constraints !reducing intercept by 200 cfs to cover most of the months with shortage in DSM2
    }
    case other {
        condition always
        rhs max(0.,ndd)
        }
}

/*define nddlimitest {  !Moved to ExportEstimate1 files
   case less20K {
        condition Q_SAC048corr <= 20000.
 		value max(0.,min(ndd,(0.2827*Q_SAC048corr + 2671.3))) }
    case great20K {
        condition Q_SAC048corr > 20000.
        value max(0.,min(ndd,(0.1006*Q_SAC048corr + 6337.8))) }
 }*/	

goal limitNDD {D_SAC041_ISF001 < C_SAC048_ISF001 }

!Split capacity under bypass flow export cap between projects according to capacities
define SWPbypasscapshare {value max_IF_cap_SWP/(max_IF_cap_SWP + max_IF_cap_CVP)}
define CVPbypasscapshare {value max_IF_cap_CVP/(max_IF_cap_SWP + max_IF_cap_CVP)}
!Weighted so that one project can use the others share if it is not used
goal limitNDDSWP {
	lhs C_CAA003_SWP_IF + C_CAA003_CVP_IF
	rhs C_SAC048_ISF001 * SWPbypasscapshare
	lhs > rhs penalty 800.
	lhs < rhs penalty 0.
}
goal limitNDDCVP {
	lhs C_DMC000_IF 
	rhs C_SAC048_ISF001 * CVPbypasscapshare
	lhs > rhs penalty 800.
	lhs < rhs penalty 0.
}
define SWPbypasscapsharedv {alias SWPbypasscapshare kind 'debug' units 'cfs'}
define CVPbypasscapsharedv {alias CVPbypasscapshare kind 'debug' units 'cfs'}

! Have to allow an adjustment if the bypass flow export cap decreases compared to the prior cycle, which can happen due to backed up carriage water savings
! Decrease in cap minus any space below the cap in last cycle
define bypassflowcapadj {value max(0.,(C_SAC048_ISF001[NDD] - nddlimitest) - (C_SAC048_ISF001[NDD] - D_SAC041_ISF001[NDD]))}
!Calculate where to adjust, first take from Excess, then from shift
define bypassflowcapadjex {value min(bypassflowcapadj, D_SAC041_ISF001_excess[NDD])}
define bypassflowcapadjsh {value max(0.,min(bypassflowcapadj - bypassflowcapadjex, D_SAC041_ISF001_elect_tdnd[NDD]))} 


! eligible excess is still whatever the excess was in the DELTA cycle
! Diversion of excess should be whatever the D_SAC041_ISF001_excess was in the NDD cycle 
define ExcessDOforNDD {std kind 'debug' units 'cfs'}
define ExcessDO    {value ExcessDOforNDD[NDD]}
goal Excess_for_NDD1 {D_SAC041_ISF001_excess = D_SAC041_ISF001_excess[NDD] - bypassflowcapadjex}
goal Excess_for_NDD2 {D_SAC041_ISF001_excess < ExcessDO}

! Limit below was to preserve storage, not currently necessary
/*define D_SAC041_ISF001_excess_limit {select ndd_limit6 from excess_limit given excess=ExcessDO use linear}
goal MaintainDO {
	lhs D_SAC041_ISF001_excess
	case LoExcess {
		condition month>=DEC .and. month<=MAY 
		rhs D_SAC041_ISF001_excess_limit
		lhs<rhs penalty 0 } 
}*/

! TD to ND elective shift is constant from now on (fixed to NDD cycle)
! The model may also elect to move stored water in this cycle

!Lock down shift from Delta pumping to NDD to same as in NDD cycle
goal Elect_TDND  {D_SAC041_ISF001_elect_tdnd = D_SAC041_ISF001_elect_tdnd[NDD] - bypassflowcapadjsh}
goal limit_SWP_ND_ElectT {lhs C_CAA003_SWP_IF_ElectT rhs C_CAA003_SWP_IF_ElectT[NDD] - bypassflowcapadjsh * SWPbypasscapshare lhs<rhs penalty 9999. lhs>rhs penalty 9999.}
goal limit_CVP_ND_ElectT {lhs C_DMC000_IF_ElectT rhs C_DMC000_IF_ElectT[NDD] - bypassflowcapadjsh * CVPbypasscapshare lhs<rhs penalty 9999. lhs>rhs penalty 9999.}

!Also need to lock down TD exports in most cases so more water doesn't get pulled in there
!But first identify some situations where TD exports project should be allowed to adjust should not apply
define allowTDchange {
	case NDDOff {
	condition JonesIFSwitch < 0.5 .and. BanksIFSwitch < 0.5  !If NDD is off, set = 0.
		value 0. }
	case EIControl {
	condition EI_control_on > 0.5  !If there is EI control, sharing percentages may change so allow for adjustment
		value 1. }
	case otherwise {
	condition always
		value 0.}
}

goal C_CAA003_TDhold {
	lhs C_CAA003_SWP_TD
	case nochange {
	condition allowTDchange < 0.5
		rhs C_CAA003_SWP_TD[NDD]
	lhs>rhs penalty 99999.
	lhs<rhs penalty 99999.
}}

goal C_DMC000_TDhold {
	lhs C_DMC000_TD
	case nochange {
	condition allowTDchange < 0.5
		rhs C_DMC000_TD[NDD]
	lhs>rhs penalty 99999.
	lhs<rhs penalty 99999.
}}

!Lock down total TD exports always, all that should change in the sharing
goal ExportActualTDhold {
	lhs ExportActualTD
	rhs ExportActualTD[NDD]
	lhs>rhs penalty 99999.
	lhs<rhs penalty 99999.
}

!Also need to maintain this from NDD cycle to reservoirs don't rebalance
!For CVP the preference is to put the backed up carriage water benefits in Shasta rather than Folsom
!So put a slight penalty on reducing releases from Folsom
goal CVPstoragepreference {
	lhs FOLDS[MONTHLYWEIGHTED] - FOLDS
	case TDshift {
	condition TDShiftest > 0.5
	rhs 0  
	lhs>rhs penalty 10.}
	}
	
! Any change in flow at C_SAC048 should be either a reduction due to lower carriage water or
! TD export that has become ND or an increase due to add'l storage withdrawal.  There
! should be a direct relationship between change in total storage withdrawal and change
! in flow at C_SAC048. Both sides in the goal below should be either negative or positive.
! This goal will also keep other NOD ops from changing. 
goal C_SAC048_mod {C_SAC048 - C_SAC048[NDD] = swpds - swpds[NDD] 
	                              + shads - shads[NDD] 
	                              + folds - folds[NDD] 
	                              + whssw - whssw[NDD]
	                              + SP_SAC083_YBP037 - SP_SAC083_YBP037[NDD]
	                              + SP_SAC066_YBP020 - SP_SAC066_YBP020[NDD]}

! Elective release of storage for export through the NDD should be a positive change in storage withdrawal
! (Because D_SAC041_ISF001 components have to be 0 or positive, this goal basically means no backing up ever of erstwhile
! carriage water. That may not be much of an issue.)
! storage releases no longer active in this cycle 
/*goal Elect_Stor {D_SAC041_ISF001_elect_stor <  swpds - swpds[NDD]
	                              + shads - shads[NDD]
	                              + folds - folds[NDD]
	                              + whssw - whssw[NDD]}

! Tie NDD to each project's actual change in export 
goal limit_SWP_ND_ElectS {C_CAA003_SWP_IF_electS < swpds - swpds[NDD]}	                                        
goal limit_CVP_ND_ElectS {C_DMC000_IF_electS + C_CAA003_CVP_IF_electS < shads - shads[NDD]
	                                                          + folds - folds[NDD]
	                                                          + whssw - whssw[NDD]}
*/
! For SWP, model has a tendency to over release through the NDD in June,
! Per Aaron Miller at DWR a more realistic operation would be spread storage releases out through Sept
! For this reason constrain storage releases for June and July to NDD to 50% of the space under the San Luis rule curve
! moved this definition into Oroville_stor_release_est_WSI.wresl, and use it for the storage release estimate too
!define Elect_Stor_lim {value max(0.,0.5 * taf_cfs * (SWPRULECV[MONTHLYWEIGHTED] - S_SLUIS_SWP[MONTHLYWEIGHTED]))}
! storage releases no longer active in this cycle 
/*goal Elect_Storlim {
	lhs C_CAA003_SWP_IF_electS 
	case JuneJuly {
	condition month == Jun .or. month == Jul
		rhs	Elect_Stor_lim
		lhs<rhs penalty 0 }
}*/
/*
!Analysis to determine whether storage releases through NDD are necessary to support allocation
!This is applied June-Sept
!Estimated deliveries through Sept based on allocation (in taf)
! storage releases no longer active in this cycle 
goal Elect_Storlim1 {
	lhs C_CAA003_SWP_IF_electS 
	case JuneSept {
	condition month >= Jun 
		rhs	NDDstorrelease
		lhs<rhs penalty 0
}}
*/
! Applying switches to turn on or off different sources
goal switchC_CAA003_SWP_IF_excess {C_CAA003_SWP_IF_excess < SWPExcessSwitch * 99999.}
goal switchC_DMC000_IF_excess {C_DMC000_IF_excess < CVPExcessSwitch * 99999.}  
goal switchC_CAA003_CVP_IF_excess {C_CAA003_CVP_IF_excess = 0.}  !This can happen in the wheeling cycles

goal switchC_CAA003_SWP_IF_ElectT {C_CAA003_SWP_IF_ElectT < SWPTDShiftSwitch * 99999.}
goal switchC_DMC000_IF_ElectT {C_DMC000_IF_ElectT < CVPTDShiftSwitch * 99999.}  

goal switchC_CAA003_SWP_ElectS {C_CAA003_SWP_IF_ElectS = 0.}  !Storage releases don't happen until the NDD2 cycle  
goal switchC_DMC000_IF_ElectS {C_DMC000_IF_ElectS  = 0.}  !Storage releases don't happen until the NDD2 cycle  
goal switchC_CAA003_CVP_IF_ElectS {C_CAA003_CVP_IF_ElectS = 0.}  !This can happen in the wheeling cycles

!Preference for TD pumping up to 3,000 cfs in summer.
goal PreferTD {
	lhs C_DMC000_TD + C_CAA003_TD
	case JulSep {
		condition month>=JUL .and. month<=SEP
		rhs min(3000., C_DMC000_TD[MONTHLYWEIGHTED] + C_CAA003_TD[MONTHLYWEIGHTED])
		lhs<rhs penalty 1002 ! this has to overcome the negative carriage water penalty
		lhs>rhs penalty 0
	}
}
	
